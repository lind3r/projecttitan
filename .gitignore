# IDE
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Claude Code session data
.claude/

# packwiz tracks mods through .pw.toml metadata; raw JARs never belong in the repo
*.jar

# packwiz local cache (separate from the global cache dir, defensive)
.packwiz-cache/

# Embeddium regenerates this on launch and tracks local class state
config/embeddium-fingerprint.json

# Per-launch logs / crash dumps that can leak in via the live config junction
logs/
crash-reports/
*.log

# Backups created by mods or editors
*.bak

# Per-user runtime state from the live Prism instance (junctioned in)
# JEI per-world bookmarks / lookupHistory
config/jei/world/
# JEI ingredient list + recipe category sort order (personal, rewritten on GUI use)
config/jei/ingredient-list-mod-sort-order.ini
config/jei/recipe-category-sort-order.ini
# Ars Nouveau Lucene index, regenerates each launch
config/ars_nouveau/search_index/
# FTB Chunks client-side chunk display state
config/ftbchunks-client.snbt
# ForgeEndertech writes per-biome AdLods cfgs as the player visits them
config/forgeendertech/Biomes/
# Embeddium client render settings (resolution, FPS, GPU-specific) — personal
config/embeddium-options.json
# Jade tooltip plugin order + sort order (set via in-game GUI, personal)
config/jade/plugins.json
config/jade/sort-order.json

# packwiz export artifacts (ship via GitHub Releases, not git)
*.mrpack
*.zip

# Personal dev journal (Claude Code project notes)
CLAUDE.md

# Reference inspiration (stoneblock4 quest export, kept locally for cross-pack lookup)
stoneblock4_quests/

# Per-chapter scratch fragments produced by quest-polish workstream
scratch/

# Working-source images (resized copies live in kubejs/assets/)
/ore_flowers.png

# Local-only release notes and follow-up planning (referenced from CLAUDE.md, not shipped)
/RELEASE.md
/TODO.md
/update-notes-*.md

# Tooling clone unrelated to the pack
/stop-slop-main/

# Incoming RNGTech quest export (merged into config/ftbquests, kept locally)
rngtechquests/
