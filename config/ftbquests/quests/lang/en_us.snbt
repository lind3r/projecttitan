	quest.72A7C90BCF639C85.quest_desc: ["Swap to something harder with more durability than copper"]
	quest.72EA1D02D33FF39B.quest_desc: [
		"Adds an affix to the item. For magic items the limit is 2 affixes, for rare it's 6."
		"Later in the game you will be allowed to ascend magic items into rare"
	]
	quest.7431964561B74763.quest_desc: ["This is just a hint you unlocked a new hardness level. Make sure to check out the scale at Start quest line"]
	quest.74C2A8758BA6E314.quest_desc: [
		"Grab the reward from the previous quest. "
		""
		"Most modifiable RNGTech items have &3Refinement Potential&r, or RP."
		""
		"RP is the budget spent when you improve, reroll, add, or remove affixes."
		""
		"- &eMagic&r items can start with 1-2 affixes."
		"- &eRare&r items can start with 3-6 affixes."
		"- &eStage&r influences how strong natural affix tiers can be."
		"- You can turn a Magic item into Rare using ascension."
		""
		"&3Tip:&r Do not spend RP blindly. Make sure to follow the Affix Forge quest line."
		""
		"&2Upgrade:&r"
		"- Take your component"
		"- Insert it into Tool Bench"
		"- Add either Affix Injection"
		"- Click Apply"
		""
		""
		""
		"&3Tip:&r IF you already combined your tool you can always dissamble without loss"
	]
	quest.74C2A8758BA6E314.title: "Affixes"
	quest.75A6F1710FAEBD6C.quest_desc: [
		"Optional. &eCopper Solar Panels&r are the first solar upgrade after crude daylight power."
		""
		"The Solar Array Controller allows you to pool multiple panels and apply bonuses."
		""
		"&aBuild:&r"
		"- Craft a &eCopper Solar Panel&r."
		""
		"&aUse:&r"
		"- Use it as supplemental daytime power."
		"- Save larger solar planning for the array controller branch."
	]
	quest.75A6F1710FAEBD6C.quest_subtitle: "Better daylight trickle."
	quest.75A6F1710FAEBD6C.title: "Copper Solar"
	quest.77BDE15168C209AE.quest_desc: ["To charge tools you can add a connector to Tool Bench"]
