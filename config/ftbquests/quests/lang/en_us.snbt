{
	chapter.0AD3EAE735844DBF.title: "Cataclysm"
	chapter.1FC893F8FF616F48.title: "Other"
	chapter.2A40D79C070081AB.title: "Ender IO"
	chapter.2CCF8CAB76604C18.title: "Draconic Evolution"
	chapter.42519A6A037E5BBA.title: "Mekanism"
	chapter.4A2490C399770842.title: "Applied Energistics 2"
	chapter.520A598AD023ABFE.title: "Oritech"
	chapter.5ED840B0AF7CADB7.title: "Apotheosis"
	chapter.6F90D08FC5152FAA.title: "Ars Nouveau"
	chapter.6FD435CB4FAC9852.title: "Create"
	chapter.79D297A25252F981.title: "Industrial Foregoing"
	chapter.7F19CC172476E599.title: "Project Titan"
	quest.00205656D3436C2F.quest_desc: [
		"The Soul outgrows mortal physics. Light bends near the Core; weather follows your mood now."
		""
		"Surrender the &eSoul&r in netherite to draw the Titan's &eBreath&r."
	]
	quest.00205656D3436C2F.quest_subtitle: "Above mortal reach."
	quest.00205656D3436C2F.title: "Tier 9 - &eBreath of the Titan&r"
	quest.02D58EF7143851CF.quest_desc: [
		"Optional. The &eEnder Library&r and &ePearl Endshelf&r are the End-themed top tier — they push the table's &aArcana&r ceiling and unlock end-bias enchant lines."
		""
		"Layer them around your enchanting table for the deepest enchant pool the pack offers. The &eDraconic Endshelf&r is the top rung if you've got &6Draconic Evolution&r ingredients to spare."
	]
	quest.02D58EF7143851CF.quest_subtitle: "End-tier enchanting."
	quest.02D58EF7143851CF.title: "Ender Library"
	quest.02FD58F04AF14206.quest_desc: [
		"&6Ars Nouveau&r's &eWhirlisprig&r is the plant-passive familiar — bind one to a tree-rich grove with the &eMycelial Sourcelink&r and it harvests + replants while feeding the network &bSource&r."
		""
		"Bind the Whirlisprig to a tree zone; the Sourcelink nearby converts the harvest into &bSource&r continuously, no input required."
	]
	quest.02FD58F04AF14206.quest_subtitle: "Plants in. Source out."
	quest.02FD58F04AF14206.title: "Whirlisprig Grove"
	quest.04229664601A15D4.quest_desc: [
		"&dIgnis&r drops &eBulwark of the Flame&r — a charge-attack greatsword/shield. Sneak-release a charge to slam forward and stun anything you hit into a wall."
		""
		"&aHow to acquire:&r"
		"- Defeat &dIgnis&r (the Nether boss). The fight is in the &6Strong Foes&r chapter."
		"- The Bulwark drops as guaranteed boss loot."
		""
		"&7&oTip: the Bulwark scales with charge time — hold sneak longer for harder hits.&r"
	]
	quest.04229664601A15D4.quest_subtitle: "Charge. Stun. Repeat."
	quest.04229664601A15D4.title: "&6Cataclysm&r — &eBulwark of the Flame&r"
	quest.05968A0ACB30FF5D.quest_desc: [
		"The &eCrown of the Titan&r only descends on those who put down every boss the trial throws at them."
		""
		"Slay all three bosses, claim the &eCrown&r from the gateway's wake, and &dProject Titan&r is yours."
	]
	quest.05968A0ACB30FF5D.quest_subtitle: "The Titan acknowledges you."
	quest.05968A0ACB30FF5D.title: "Coronation"
	quest.064818C98216D880.quest_desc: [
		"The &eSpout&r fills items from above (buckets, bottles, anything fluid-accepting). &eItem Drain&r does the reverse — empty containers back to liquid."
		""
		"&aPress &eW&r — &ePonder&r covers belt-feeding both blocks and fluid-pipe routing.&r"
	]
	quest.064818C98216D880.quest_subtitle: "Pour, drain, repeat."
	quest.064818C98216D880.title: "Spout and Drain"
	quest.06E74F5AEB182610.quest_desc: ["&6Ars Nouveau&r's &eMagebloom&r is the renewable arcane crop. Plant seeds on tilled soil — growth is slower than vanilla wheat, but the harvest refines into &eMagebloom Fiber&r for robes or compresses into &eMagebloom Blocks&r for high-tier recipes."]
	quest.06E74F5AEB182610.quest_subtitle: "The slow garden."
	quest.06E74F5AEB182610.title: "Cultivate"
	quest.071642CB7D12C35D.quest_desc: [
		"&6Create&r's kinetic miner pair — &eMechanical Drill&r breaks blocks in front, &eMechanical Saw&r fells trees and mills logs into planks. Both run on shaft power."
		""
		"&aPress &eW&r — &ePonder&r shows the contraption-mounted variants and orientation rules.&r"
	]
	quest.071642CB7D12C35D.quest_subtitle: "Two cuts. Many things."
	quest.071642CB7D12C35D.title: "Mechanical Drill and Saw"
	quest.0A75FF5E927E69E3.quest_desc: ["&6Industrial Foregoing&r is a quirky tech mod with biofuel generators, automated farms, and mob-grinding machines. Plastic is its core resource — make it once, build everything from it."]
	quest.0A75FF5E927E69E3.quest_subtitle: "Plastic. Pink slime. Lazer drills."
	quest.0A75FF5E927E69E3.title: "&6Industrial Foregoing&r"
	quest.0A813C4D5E6F7283.quest_desc: [
		"&6Ender IO&r's lazy-farmer blueprint. Stick saplings, seeds, or netherwart in the &eFarming Station&r's slots, feed it &aForge Energy&r, and walk away."
		""
		"Outputs land in the bottom buffer — pair with the &eConduits&r quest's pipework to bus crops out and seeds back in."
	]
	quest.0A813C4D5E6F7283.quest_subtitle: "Plant it. Forget it."
	quest.0A813C4D5E6F7283.title: "Farming Station"
	quest.0A9CF0B826AF71FF.quest_desc: [
		"&eWireless Terminal&r + &eWireless Access Point&r = your network in your pocket. Crafting variant adds the inline grid wherever you stand."
		""
		"&aPress &eG&r — &eGuideME&r → &eWireless&r covers range and battery.&r"
	]
	quest.0A9CF0B826AF71FF.quest_subtitle: "Network on the go."
	quest.0A9CF0B826AF71FF.title: "Wireless Access"
	quest.0AEACF41C1ED1FBA.quest_desc: [
		"&aWorth knowing&r — &6Industrial Foregoing&r odds and ends:"
		""
		"- &eConveyor&r — IF's belt. Glass-painted variants for color-routing."
		"- &eFluid Pump&r / &eFluid Extractor&r — pull fluid from world or block."
		"- &eFluid Placer&r / &eFluid Collector&r — fluid-block placement automation."
		"- &eMaterial Stonework Factory&r — convert cobble → stone → smooth → bricks → … in one block."
		"- &eEnchantment Extractor/Applicator&r — peel an enchant off a tool, slap it on another."
		"- &eAnimal Rancher&r — cow farm in a box (milk + leather, no killing)."
		"- &eAnimal Feeder&r / &eBaby Separator&r — passive breeding factory."
		"- &eMycelial Reactor&r — IF's modular FE generator that runs on themed mushroom blocks."
		"- &eVillager Trade Exchanger&r — automate trades."
	]
	quest.0AEACF41C1ED1FBA.quest_subtitle: "Worth knowing — Industrial Foregoing."
	quest.0AEACF41C1ED1FBA.title: "Industrial Foregoing Bric-a-Brac"
	quest.0C998F80BDBE5530.quest_desc: [
		"The Heart is forged. The &dTitan&r now demands proof."
		""
		"Accepting this challenge surrenders a &eGate Pearl&r bound to the &dTitan Trial&r — a single-wave gauntlet of the &dEnder Guardian&r, the &dNetherite Monstrosity&r, and &dIgnis&r, each at twice their natural stats."
		""
		"&cOpen it only in a prepared arena, far from anything you would mourn losing.&r"
		""
		"&7&oTip: the Pearl is consumed when the gateway opens — there is only one attempt per craft.&r"
	]
	quest.0C998F80BDBE5530.quest_subtitle: "Take up the gate."
	quest.0C998F80BDBE5530.title: "The Trial Awaits"
	quest.0C99F5AA659FF526.quest_desc: [
		"&6Create&r turns mechanical rotation into everything: presses, mixers, crushing wheels, contraptions that move themselves. Pair with the &6Crafts and Additions&r addon for the alternator that bridges to FE."
		""
		"&aHover any &6Create&r block in your inventory and press &eW&r to open &ePonder&r — animated scenes show every block in motion. Better than any quest description.&r"
	]
	quest.0C99F5AA659FF526.quest_subtitle: "Rotation in. Power, fluids, items out."
	quest.0C99F5AA659FF526.title: "&6Create&r"
	quest.0D76974DDD5A95B7.quest_desc: ["&6YUNG's&r expanded &eWitch Huts&r and rare &eWitch Circles&r — the swamp's most iconic structure, now worth a visit."]
	quest.0D76974DDD5A95B7.quest_subtitle: "Witch convention venues."
	quest.0D76974DDD5A95B7.title: "&6Better Witch Huts&r"
	quest.0FE97A6346E80276.quest_desc: [
		"&aWorth knowing&r — &6Create&r odds and ends:"
		""
		"- &eEngineer's Goggles&r — show stress, speed, and capacity overlays. Wear them while building any kinetic network."
		"- &eWrench&r — rotate any Create block. Sneak-wrench to break and pick up."
		"- &eLinked Controller&r — bind it to track stations and remote-drive trains."
		"- &eSmart Chute&r / &eSmart Observer&r — filter-aware chutes and signal-emitters."
		"- &eBrass Tunnel&r — splits a single belt's items across multiple outputs by filter."
		"- &eGantry Carriage&r + &eGantry Shaft&r — Create's linear actuator. Move and run machines along an axis."
		"- &ePotato Cannon&r — joke weapon, surprisingly viable mid-game."
		"- &eClipboard&r — multi-page inventory for managing redstone/train logic notes."
		""
		"&aPress &eW&r on any of these in your inventory — &ePonder&r animates each one.&r"
	]
	quest.0FE97A6346E80276.quest_subtitle: "Worth knowing — Create."
	quest.0FE97A6346E80276.title: "Create Bric-a-Brac"
	quest.117C8EAB9186A37B.quest_desc: [
		"&6Oritech&r's &eFoundry&r is the molten-metal route — pour ingots in, get hotter alloys out. The path to &eSteel&r and &eAdamant&r runs through here."
		""
		"Iron + coal smelts to &eSteel&r straight away. Higher tiers (&eAdamant&r, &eDuratium&r) need molten flux as catalyst — pipe it in from a refinery."
	]
	quest.117C8EAB9186A37B.quest_subtitle: "Pour, alloy, repeat."
	quest.117C8EAB9186A37B.title: "Foundry"
	quest.11EEA6D3745C178A.quest_desc: [
		"The &ePressurized Reaction Chamber&r is the &aitem + fluid + gas&r recipe machine — three inputs at once. The flagship recipe is &eSubstrate&r → &eHDPE Pellet&r → &eHDPE Sheet&r, the plastic line that gates &eMekaSuit&r and modules."
		""
		"Sequence: bio-fuel + water + hydrogen makes &eSubstrate&r; substrate + ethene makes &eHDPE Pellet&r; press the pellets into &eHDPE Sheet&r at an &eEnrichment Chamber&r."
	]
	quest.11EEA6D3745C178A.quest_subtitle: "Three inputs. One reaction."
	quest.11EEA6D3745C178A.title: "Pressurized Reaction Chamber"
	quest.132F45785EF7857E.quest_desc: [
		"&eME Drive&r holds 10 storage cells. Cells stack types and bytes — bigger cells (1k → 256k) cost more processors but hold dramatically more types."
		""
		"&aPress &eG&r — &eGuideME&r → &eStorage&r covers cell math and partitioning.&r"
	]
	quest.132F45785EF7857E.quest_subtitle: "Storage at scale."
	quest.132F45785EF7857E.title: "ME Drive/Cells"
	quest.165B94D41DEEDB88.quest_desc: [
		"&aWorth knowing&r — &6Draconic Evolution&r odds and ends:"
		""
		"- &eDraconium Chest&r — multiblock-expansion chest, dimensions scale with structure."
		"- &eAdvanced Magnet&r — pulls drops to you in a wide radius; toggleable."
		"- &eFlux Gate&r — meter and clamp FE flow on a line."
		"- &eGenerator&r — burns furnace fuel for FE; mostly used during initial DE setup."
		"- &eGrinder&r — DE's automatic mob killer; reads tagged spawn pads."
		"- &eEntity Detector&r / &eEntity Detector Advanced&r — redstone outputs based on entity counts/types."
		"- &eDisenchanter&r — pulls enchantments off gear and stores in books."
		"- &eParticle Generator&r — visual effect block for builds."
		""
		"&7&oTip: read the &eDE Information Tablet&r (in JEI) for the full picture — DE's recipe map is unusually deep.&r"
	]
	quest.165B94D41DEEDB88.quest_subtitle: "Worth knowing — Draconic Evolution."
	quest.165B94D41DEEDB88.title: "Draconic Evolution Bric-a-Brac"
	quest.17F8A0B1C2D3E500.quest_desc: ["&6Apotheosis&r &eBoss Summoners&r conjure a randomized &aaffixed&r boss with rare-tier loot. Crafted from rare materials and arcane essence."]
	quest.17F8A0B1C2D3E500.quest_subtitle: "Apoth's craftable arena — pick your fight, on your schedule."
	quest.17F8A0B1C2D3E500.title: "Summon a Boss"
	quest.17F8A0B1C2D3E510.quest_desc: ["&eApothic Spawners&r are &aspawners&r you can break, pick up, and re-place — turning any monster into a renewable XP and drop farm."]
	quest.17F8A0B1C2D3E510.quest_subtitle: "Capture and replant."
	quest.17F8A0B1C2D3E510.title: "Spawner Husbandry"
	quest.17F8A0B1C2D3E520.quest_desc: ["The &dHarbinger&r is &6Cataclysm&r's first true boss — a massive tower-of-doom with phases. Summons in the Overworld via spawn egg or world generation."]
	quest.17F8A0B1C2D3E520.quest_subtitle: "Tear down the tower."
	quest.17F8A0B1C2D3E520.title: "Slay the &dHarbinger&r"
	quest.17F8A0B1C2D3E530.quest_desc: ["The &dLeviathan&r is the underwater terror — invincible outside water, devastating inside. The fight forces you to engage on its terms."]
	quest.17F8A0B1C2D3E530.quest_subtitle: "Drown its drowner."
	quest.17F8A0B1C2D3E530.title: "Slay the &dLeviathan&r"
	quest.17F8A0B1C2D3E540.quest_desc: ["&dBone Serpents&r spawn in the Nether and chase aggressively. They drop Bone Serpent Tooth (Nether tooth weapon component) and rarely Soul Heart (used to craft Soul Vulture armor)."]
	quest.17F8A0B1C2D3E540.quest_subtitle: "Three serpents. One trophy."
	quest.17F8A0B1C2D3E540.title: "Hunt the &dBone Serpent&r"
	quest.17F8A0B1C2D3E550.quest_desc: ["The &dEnder Guardian&r rules the &eRuined Citadel&r — a rare End structure (Highlands or Midlands) you can hunt down with an &eEye of Void&r. The fight starts when you approach the altar at the citadel's lowest level; phase two smashes the floor out from under you."]
	quest.17F8A0B1C2D3E550.quest_subtitle: "Crack the void's keeper."
	quest.17F8A0B1C2D3E550.title: "Slay the &dEnder Guardian&r"
	quest.17F8A0B1C2D3E560.quest_desc: ["&dIgnis&r spawns inside Nether Fortresses as the awakened form of the Ignited Berserkers — a fire-aligned super-boss with abyss fireballs, flame strikes, and a phase-two damage spike."]
	quest.17F8A0B1C2D3E560.quest_subtitle: "Light the fortress's fire out."
	quest.17F8A0B1C2D3E560.title: "Slay &dIgnis&r"
	quest.17F8A0B1C2D3E570.quest_desc: [
		"&6Apotheosis&r weaves &aaffixes&r into ordinary mobs — randomized prefixes and suffixes that turn a normal zombie into a glass-cannon archer or an armored damage-sponge. Each rarity tier of &aaffixed&r mob drops a different rarity material when slain."
		""
		"Kill any common-rarity &aaffixed&r mob — a Mysterious Scrap Metal will drop, and that's the signal."
	]
	quest.17F8A0B1C2D3E570.quest_subtitle: "Common drops, uncommon kills."
	quest.17F8A0B1C2D3E570.title: "The Affixed"
	quest.17F8A0B1C2D3E580.quest_desc: [
		"Gate Pearls open Gateways — beacon-like columns that summon waves of mobs and drop loot at the end. Find pearls in dungeon loot, craft them, or buy them, then use one on the ground in open space."
		""
		"Clearing any Gateway counts. Practice on the basics — the pack's endgame &dTitan Trial&r is the same mechanic, dialed up."
	]
	quest.17F8A0B1C2D3E580.quest_subtitle: "Drop the pearl. Stand your ground."
	quest.17F8A0B1C2D3E580.title: "Open a Gateway"
	quest.17F8A0B1C2D3E590.quest_desc: [
		"&6Draconic Evolution&r's &dChaos Guardian&r rules the End — a void-aligned dragon-class boss flanked by Guardian Crystals you must shatter before the Guardian itself becomes vulnerable. Drops the Chaos Shard, the gateway material to Chaotic-tier gear (Wyvern → Awakened → Chaotic)."
		""
		"Find it on End islands far from the central island. Bring an Energy Core's worth of charge and Awakened armor."
	]
	quest.17F8A0B1C2D3E590.quest_subtitle: "End-shard. Beam attacks. Phase three is real."
	quest.17F8A0B1C2D3E590.title: "Slay the &dChaos Guardian&r"
	quest.180CDEEEEDD654AE.quest_desc: [
		"&eAdvanced Dislocator&r is &6DE&r's tag-and-teleport — bind it to a location, set a destination, and right-click to teleport. Pair the handheld with a &ePedestal&r at one end and a &eReceptacle&r at the other for a permanent two-way portal."
		""
		"Right-click the pedestal with the dislocator to bind, then right-click anywhere to teleport home."
	]
	quest.180CDEEEEDD654AE.quest_subtitle: "Two-stop travel."
	quest.180CDEEEEDD654AE.title: "Dislocator"
	quest.18852E1D544D601B.quest_desc: ["&6Cataclysm&r drops four custom bosses — &dHarbinger&r, &dLeviathan&r, &dEnder Guardian&r, &dIgnis&r — each gating a unique gear set. The Titan Trial endgame remixes three of them at 2× stats."]
	quest.18852E1D544D601B.quest_subtitle: "Four bosses. One arms race."
	quest.18852E1D544D601B.title: "&6L_Ender's Cataclysm&r"
	quest.19569F0287337478.quest_desc: [
		"The &eElectrolytic Separator&r splits &bwater&r into &bhydrogen&r + &boxygen&r. Pipe water in; pipe each gas out a separate side."
		""
		"&bHydrogen&r feeds the &eJetpack&r and &eGas Burning Generator&r; &boxygen&r feeds the &ePurification Chamber&r for 3× ore."
		""
		"&7&oTip: an Infinite Water Cell or autonomous water source on input is the cleanest setup.&r"
	]
	quest.19569F0287337478.quest_subtitle: "Two gases. Two pipelines."
	quest.19569F0287337478.title: "Electrolytic Separator"
	quest.1A2B3C4D5E6F7081.quest_desc: [
		"&6Macaw's&r is five mods in a trenchcoat: &6Windows&r, &6Doors&r, &6Roofs&r, &6Furniture&r, &6Lights&r. Together they fix vanilla's biggest decoration gap — buildings worth looking at."
		""
		"Build one signature block from each mod: a window, a Japanese door, a roof tile, a chair, and a lamp."
	]
	quest.1A2B3C4D5E6F7081.quest_subtitle: "Five mods. One toolkit for buildings worth living in."
	quest.1A2B3C4D5E6F7081.title: "&6Suburban Architect&r"
	quest.1A2B3C4D5E6F70A1.quest_desc: ["&6Chisel&r turns common building blocks into dozens of decorative variants. Hold the &eChisel&r and right-click a block to open the variant picker."]
	quest.1A2B3C4D5E6F70A1.quest_subtitle: "One block, fifty variants."
	quest.1A2B3C4D5E6F70A1.title: "&6Chisel&r"
	quest.1A2B3C4D5E6F70B1.quest_desc: [
		"&6Spice of Life: Carrot Edition&r tracks every unique food you've eaten. Hit milestones (5, 10, 20, 30, …) and your max health permanently rises — eventually well past vanilla 20."
		""
		"Craft the &eFood Book&r to see your progress."
	]
	quest.1A2B3C4D5E6F70B1.quest_subtitle: "Variety is max health."
	quest.1A2B3C4D5E6F70B1.title: "&6Eat Your Veggies&r"
	quest.1A2B3C4D5E6F70C1.quest_desc: ["The &6Crafting Station&r is a 3×3 crafter that remembers — drop ingredients in, browse JEI inline, click a recipe to auto-fill. The grid stays loaded between visits, so half-finished crafts wait for you. It can also use contents from adjacent inventories, like a Diamond Barrel."]
	quest.1A2B3C4D5E6F70C1.quest_subtitle: "Crafting that remembers."
	quest.1A2B3C4D5E6F70C1.title: "&6Crafting Station&r"
	quest.1A2B3C4D5E6F70D1.quest_desc: [
		"&6Trash Cans&r void what they receive — items, fluids, energy, or all three. Filter-aware, transfer-rate-limited, hopper-friendly."
		""
		"Craft the &eItem Trash Can&r."
	]
	quest.1A2B3C4D5E6F70D1.quest_subtitle: "Make the cobble go away."
	quest.1A2B3C4D5E6F70D1.title: "&6Trash Cans&r"
	quest.1A5D8E3B7C90F4A2.quest_desc: [
		"Before any tier shard can be drawn, the &eTitan Core&r itself must exist. The block is the altar — every shard recipe lights up only when the Core is placed and powered."
		""
		"Forge it, set it down where you intend to live, and bring &aForge Energy&r."
	]
	quest.1A5D8E3B7C90F4A2.quest_subtitle: "Place the altar."
	quest.1A5D8E3B7C90F4A2.title: "Forge the Titan Core"
	quest.1A6D32ADD93267FB.quest_desc: [
		"Something looks back through the projection. It has wants. They are not yours."
		""
		"Open the &eVoice&r in emerald — the &eSoul&r answers."
		""
		"&aWorld Tier:&r completing this quest advances you to &ePinnacle&r — the final Apothic step. Mob HP, damage, affix rolls, and Mythic loot density all max out."
	]
	quest.1A6D32ADD93267FB.quest_subtitle: "It dreams."
	quest.1A6D32ADD93267FB.title: "Tier 8 - &eSoul of the Titan&r"
	quest.1B0A57BB7ED47822.quest_desc: [
		"&6Ender IO&r's &eAlloy Smelter&r is the gateway to all four EIO alloys — &eEnergetic&r, &eVibrant&r, &ePulsating&r, &eRedstone Alloy&r. Steel-tier dependency for the SAG Mill, Capacitor Bank, and Enchanter."
		""
		"Three ingredients per recipe, alloy ingot out. Pair with the &eSAG Mill&r for grinding-ball-boosted ore yields."
	]
	quest.1B0A57BB7ED47822.quest_subtitle: "All four alloys, one block."
	quest.1B0A57BB7ED47822.title: "Alloy Smelter"
	quest.1B924D5E6F708394.quest_desc: [
		"&6Mekanism&r's wireless-everything block. Place two &eQuantum Entangloporters&r on the same frequency anywhere in the world and items, fluids, gases, &aForge Energy&r, and heat all flow between them — no cables, no chunk-loading."
		""
		"Set a frequency, configure the channel tabs (items / fluids / gases / energy / heat), and a matched pair swaps their inventories instantly. The recipe — &eAtomic Alloy&r, an &bAntimatter Pellet&r, and a &eTeleportation Core&r — is the gating cost; that's the point."
		""
		"&7&oTip: every channel on a frequency is shared globally — name your frequencies, or two unrelated bases will start dumping items into each other.&r"
	]
	quest.1B924D5E6F708394.quest_subtitle: "Wireless everything, anywhere."
	quest.1B924D5E6F708394.title: "Quantum Entangloporter"
	quest.1CA0297140031A1C.quest_desc: [
		"The &eAlteration Table&r upgrades &6Ars&r-side gear — slot armor + reagent + spell + perk to imbue, swap, or replace properties on a piece of &eMage Robes&r. Pair it with an &eEnchanting Apparatus&r."
		""
		"Place gear and choose the alteration. Threads (&eThread of the Drygmy/Starbuncle/Whirlisprig/Wixie&r) bind set bonuses based on your familiar."
	]
	quest.1CA0297140031A1C.quest_subtitle: "Robes, customized."
	quest.1CA0297140031A1C.title: "Alteration Table"
	quest.1CE70C5907125D06.quest_desc: [
		"The &eEIO Crafter&r is the auto-crafting block — slot a recipe template, feed it ingredients via conduits, and it produces output as long as inputs are available."
		""
		"Open the GUI to lock in the recipe pattern. Pipe ingredients in via item conduits and route the output to a chest or further automation."
	]
	quest.1CE70C5907125D06.quest_subtitle: "Recipes that run themselves."
	quest.1CE70C5907125D06.title: "EIO Crafter"
	quest.1D35C6223BDD9FA1.quest_desc: [
		"&6Oritech&r's basic processing pair. The &ePulverizer&r doubles ores into clumps; the &eCentrifuge&r turns clumps into dust, then dust into ingots — 2× yield over a vanilla furnace."
		""
		"Raw ore goes in the Pulverizer; pipe the clumps to the Centrifuge; smelt the dust output to claim the multiplier."
	]
	quest.1D35C6223BDD9FA1.quest_subtitle: "Crush. Spin. Multiply."
	quest.1D35C6223BDD9FA1.title: "Ore Processing"
	quest.1DB508C752281D92.quest_desc: [
		"&aWorth knowing&r — &6Cataclysm&r odds and ends:"
		""
		"- &eAthame&r — life-steal dagger; drops from &eDeepling Warlocks&r and &ePriests&r in the &eSunken City&r."
		"- &eVoid Forge&r — End boss-tier handheld; uses &eVoid Cores&r as ammunition."
		"- &eGauntlet of Bulwark&r / &eof Maelstrom&r — punching gauntlets with elemental specials."
		"- &eAstrape&r / &eCeraunus&r — lightning-themed bow/spear from the storm boss line."
		"- &eAbyssal Sacrifice&r — opens the Drowned World boss arena (Leviathan summon item)."
		"- &eBerserker Soul Amulet&r — curio that swaps damage scaling for missing-HP."
		"- &eVoid Eye&r / &eFlame Eye&r / &eStorm Eye&r — boss summon catalysts."
		"- &eMusic Discs&r (Harbinger, Leviathan, Ignis, Ender Guardian) — boss-themed records."
	]
	quest.1DB508C752281D92.quest_subtitle: "Worth knowing — Cataclysm."
	quest.1DB508C752281D92.title: "Cataclysm Bric-a-Brac"
	quest.1F86FF003387AE4E.quest_desc: [
		"&6Ars Nouveau&r's &eEnchanting Apparatus&r is the multi-block crafting bench surrounded by &eArcane Pedestals&r. The &eImbuement Chamber&r is its lower-tier sibling — a passive crafter for simpler recipes."
		""
		"Both need &bSource&r within reach (Jar or Relay nearby). For the Apparatus, drop ingredients onto the surrounding pedestals, place the recipe item on the apparatus itself, then right-click to craft. For the Imbuement Chamber, drop in an input and let &bSource&r do the work passively."
	]
	quest.1F86FF003387AE4E.quest_subtitle: "Where glyphs become gear."
	quest.1F86FF003387AE4E.title: "The Workshop"
	quest.1FCD148E2DA620F0.quest_desc: [
		"The Core wakes for the first time. A mote — barely more than dust — lifts from the crafting beam."
		""
		"Complete the T1 recipe at the Core to obtain the &eMote&r."
		""
		"&aWorld Tier:&r completing this quest advances you to &eHaven&r — Apothic's first hardening step. Mobs gain HP, low-rarity affixes start rolling on drops."
	]
	quest.1FCD148E2DA620F0.quest_subtitle: "The first spark."
	quest.1FCD148E2DA620F0.title: "Tier 1 - &eMote of the Titan&r"
	quest.2187565E5FB2D337.quest_desc: [
		"The &eRolling Mill&r turns ingots into rods and wire — gateway items for &6Createaddition&r's electrical recipes."
		""
		"&aPress &eW&r — &ePonder&r animates the input/output and shaft-power requirements.&r"
	]
	quest.2187565E5FB2D337.quest_subtitle: "Ingots in. Rods out."
	quest.2187565E5FB2D337.title: "Rolling Mill"
	quest.21C1DCB0B2D791A0.quest_desc: [
		"&dAncient Remnant&r is the colossal skeletal beast buried beneath the &eCursed Pyramid&r — the structure's main boss, dwarfing the Wadjet that guards its halls. Drops &eSandstorm in a Bottle&r, &eAncient Metal&r, and a &eRemnant Skull&r used to tame your own Modern Remnant companion."
		""
		"&aHow to acquire:&r"
		"- Excavate the suspicious sand inside a &eCursed Pyramid&r to wake it."
		"- The arena is wide for a reason — the Remnant's stomp shockwaves outrange most melee."
	]
	quest.21C1DCB0B2D791A0.quest_subtitle: "Buried, not dead."
	quest.21C1DCB0B2D791A0.title: "Slay the &dAncient Remnant&r"
	quest.22950E7EDF0BC8BA.quest_desc: [
		"The &eMob Duplicator&r is the inverse of the &eMob Crusher&r — fed &eMob Imprisonment Tools&r (charged by right-clicking a target mob), it spawns copies on a powered timer."
		""
		"Power + &bEssence&r fluid + a charged tool produces a continuous mob stream. Pair it with the &eMob Crusher&r for a complete loop: duplicate → kill → drops + XP."
	]
	quest.22950E7EDF0BC8BA.quest_subtitle: "Loot loop, automated."
	quest.22950E7EDF0BC8BA.title: "Mob Duplicator"
	quest.25A67DAD153BF6BF.quest_desc: [
		"&aWorth knowing&r — &6Ars Nouveau&r odds and ends:"
		""
		"- &eJar of Light&r — bottled light source you can place anywhere; reusable."
		"- &eVoid Jar&r — held trash can with a filter; void unwanted drops on pickup."
		"- &eSource Jar&r — &bSource&r battery; place near &eRelays&r to network."
		"- &eRelay&r / &eRelay Splitter&r / &eRelay Warp&r — light-based source pipelines."
		"- &eMagelight Torch&r — invisible torch; lights without the block."
		"- &eMage Block&r — invisible solid; useful for traps and elaborate spell setups."
		"- &eRitual of Flight&r — once cast, persistent flight in an area."
		"- &eFamiliar threads&r — slot in armor for set bonuses tied to your familiar."
	]
	quest.25A67DAD153BF6BF.quest_subtitle: "Worth knowing — Ars Nouveau."
	quest.25A67DAD153BF6BF.title: "Ars Nouveau Bric-a-Brac"
	quest.25E8D26BFF731ED7.quest_desc: [
		"&eLogistical Transporters&r are Mek's pipes — like vanilla hoppers, but with tiered speed and color filters. Pair with a &eLogistical Sorter&r on the source side to filter what goes where."
		""
		"The Sorter pulls items from a chest into the transporter line based on filter rules; color tabs route each item to the matching color on the destination."
	]
	quest.25E8D26BFF731ED7.quest_subtitle: "Pipes, with rules."
	quest.25E8D26BFF731ED7.title: "Logistical Transport"
	quest.25F6779B61EC443B.quest_desc: [
		"Factories are the batched form of every &6Mekanism&r unit machine — Smelter, Enricher, Crusher, Compressor, Combiner, Sawmill, Infuser, Purifier, Injector. Tier rotations: &eBasic&r (3 slots) → &eAdvanced&r (5) → &eElite&r (7) → &eUltimate&r (9)."
		""
		"Right-click a placed factory with a &eTier Installer&r to bump it in place — no rebuild, contents preserved. The same installers also upgrade Energy Cubes, Bins, and the entire transport family (cable / pipe / tube / conductor)."
		""
		"&7&oA 9-slot Ultimate Smelter parallelises nine Energized Smelters into one block.&r"
	]
	quest.25F6779B61EC443B.quest_subtitle: "Parallelize the basics."
	quest.25F6779B61EC443B.title: "Factories"
	quest.2626168DFFC6D35B.quest_desc: [
		"The &eEnergized Smelter&r is the &aFE&r-powered drop-in replacement for a furnace — faster, no fuel, and stackable behind a Crusher for ore-processing convenience."
		""
		"Pipe ore or dust in, take ingots out. Pair with the &eEnrichment Chamber&r in the same line for the 2× ore route."
	]
	quest.2626168DFFC6D35B.quest_subtitle: "Smelting at the speed of FE."
	quest.2626168DFFC6D35B.title: "Energized Smelter"
	quest.271081B9C92EB85D.quest_desc: ["&6YUNG's&r expanded &eDungeons&r — the surface and underground spawner rooms, now with proper architecture and tougher loot."]
	quest.271081B9C92EB85D.quest_subtitle: "Spawner rooms with character."
	quest.271081B9C92EB85D.title: "&6Better Dungeons&r"
	quest.2804065C0AD6C566.quest_desc: [
		"The mote settles into a steady ember. Small, but it has a temperature now — and a temperament."
		""
		"Feed the &eMote&r back into the Core with iron to ignite the &eEmber&r."
		""
		"&aWorld Tier:&r completing this quest advances you to &eFrontier&r. Affix rarity ceiling rises and rare-tier loot starts dropping with regularity."
	]
	quest.2804065C0AD6C566.quest_subtitle: "It begins to burn."
	quest.2804065C0AD6C566.title: "Tier 2 - &eEmber of the Titan&r"
	quest.280A1B2C3D4E5F80.quest_desc: ["End-tier materials gate a lot of late progression. The journey to &dthe End&r and back is its own story."]
	quest.280A1B2C3D4E5F80.quest_subtitle: "Find the portal. Take the leap."
	quest.280A1B2C3D4E5F80.title: "Visit &dthe End&r"
	quest.280A1B2C3D4E5F90.quest_desc: ["&dStrongholds&r in this pack are upgraded by &6Yung's Better Strongholds&r — bigger, more dangerous, more rewarding."]
	quest.280A1B2C3D4E5F90.quest_subtitle: "Find the eyes. Find the fortress."
	quest.280A1B2C3D4E5F90.title: "Find a &dStronghold&r"
	quest.280A1B2C3D4E5FA0.quest_desc: ["&6Terralith&r adds dozens of biomes that vanilla never imagined. The &dAmethyst Rainforest&r is one of the showpieces — purple, dense, dripping with amethyst geodes."]
	quest.280A1B2C3D4E5FA0.quest_subtitle: "Walk into purple."
	quest.280A1B2C3D4E5FA0.title: "&dAmethyst Rainforest&r"
	quest.280A1B2C3D4E5FC0.quest_desc: [
		"&6Towns and Towers&r expands vanilla villages into themed settlements — Mediterranean, Tudor, Iberian, Oriental, Piglin, and more — each biome gets its own architecture."
		""
		"Find any Towns-and-Towers village to satisfy."
	]
	quest.280A1B2C3D4E5FC0.quest_subtitle: "Find a town worth visiting."
	quest.280A1B2C3D4E5FC0.title: "Find a &dTown&r"
	quest.280A1B2C3D4E5FD0.quest_desc: ["&6When Dungeons Arise&r scatters elaborate hand-built dungeons across the world — towers, castles, mansions, illager forts. The &dBandit Towers&r are the iconic mid-tier challenge."]
	quest.280A1B2C3D4E5FD0.quest_subtitle: "Climb the bandit towers."
	quest.280A1B2C3D4E5FD0.title: "Find &dBandit Towers&r"
	quest.289518C7EC5A44EC.quest_desc: [
		"&eStable Warp Scroll&r is &6Ars Nouveau&r's persistent fast-travel — sneak-right-click anywhere to bind, then right-click later to teleport back. Cheap, range-unlimited, dimension-spanning. Re-bind freely."
		""
		"&7&oTip: keep one in a Curio slot, sneak-set on every base. Free travel forever.&r"
	]
	quest.289518C7EC5A44EC.quest_subtitle: "Persistent waypoints."
	quest.289518C7EC5A44EC.title: "Warp Scrolls"
	quest.28A1B2C3D4E5F600.quest_desc: [
		"&6Ars Nouveau&r's &eDrygmy&r is the automation pet — bind it to a captured mob and it passively collects that mob's drops over time without ever fighting."
		""
		"Set up a contained pen for the target mob, summon a Drygmy with the charm, and bind it to the pen. Drops accumulate in a nearby chest — no combat involved."
	]
	quest.28A1B2C3D4E5F600.quest_subtitle: "Mob loot, the lazy way."
	quest.28A1B2C3D4E5F600.title: "Drygmy Charm"
	quest.296A145EEC9F228D.quest_desc: [
		"&6Apothic Enchanting&r's mid-tier shelves push the &aEterna&r/&aQuanta&r/&aArcana&r table stats far past vanilla. The &eLibrary&r block stores enchanted books for filtering what enchants are available; biome-themed shelves (&eBeeshelf&r, &eCrystal Seashelf&r) are the diversity boost."
		""
		"Place the Library next to your enchanting table and mix shelf types around it — variety raises Arcana and unlocks rare enchant lines."
	]
	quest.296A145EEC9F228D.quest_subtitle: "The middle library."
	quest.296A145EEC9F228D.title: "Library and Mid-Tier Shelves"
	quest.2A49B70413B7164F.quest_desc: [
		"&eObelisks&r are area-effect mob controllers — &eAttractor&r pulls mobs toward it, &eAversion&r pushes them away, &eInhibitor&r prevents spawning entirely in its radius. Range scales with capacitor tier."
		""
		"Drop an Attractor at a farm choke point with a damage source for a passive grinder; ring an Aversion or Inhibitor around your factory for a safe zone."
	]
	quest.2A49B70413B7164F.quest_subtitle: "Pull. Push. Suppress."
	quest.2A49B70413B7164F.title: "Obelisks"
	quest.2A9ABC7163AD5A2D.quest_desc: [
		"The &eDissolution Chamber&r is &6IF&r's plastic factory — fed by a &eLatex Processing Unit&r tapping a tree, it converts latex + sugar cane into &eTiny Dry Rubber&r, which compresses 9× into a &ePlastic Sheet&r."
		""
		"Plastic gates the &eAdvanced Machine Frame&r and most of IF's tier 2."
	]
	quest.2A9ABC7163AD5A2D.quest_subtitle: "Latex in. Plastic out."
	quest.2A9ABC7163AD5A2D.title: "Dissolution Chamber"
	quest.2BC9F4A1E8D5670F.quest_desc: [
		"&6Welcome to Project Titan.&r"
		""
		"The Core stands silent at the heart of your world. Forging it — and feeding it — is the long work of this pack."
		""
		"Other chapters branch out into power, resources, gear, and the wider world. They are companions to this spine, not prerequisites. Wander where you like; return here when you are ready to forge the first &eMote&r."
		""
		"&aApothic World Tiers:&r select tier completions (&eT1, T2, T4, T6, T8&r) auto-advance your world tier — &eHaven → Frontier → Ascent → Summit → Pinnacle&r. Each step hardens mobs, lifts affix rarity caps, and unlocks new Mythic loot. The world levels with you."
		""
		"&cHeads up:&r vanilla ore generation is disabled. Ores spawn as rare &emotherlode deposits&r with flower rings on the surface. See &6Reading the Earth&r in the &eOther&r chapter for the full picture before you go mining."
	]
	quest.2BC9F4A1E8D5670F.quest_subtitle: "The Core stirs."
	quest.2BC9F4A1E8D5670F.title: "Welcome to Project Titan"
	quest.2C035E6F70819481.quest_desc: [
		"&6Apotheosis&r's &eSalvaging Table&r breaks down any &aaffixed&r item into the rarity material of its tier — Common scrap up through &eMythic&r dust. Bad rolls become reforging fuel."
		""
		"Place it next to your &eReforging Table&r. Drop in an unwanted affix item; you get the rarity material for its tier — salvage a Rare-tier piece to claim the &eLuminous Crystal Shard&r this quest is asking for."
	]
	quest.2C035E6F70819481.quest_subtitle: "Junk in, currency out."
	quest.2C035E6F70819481.title: "&6Apotheosis&r: &eSalvaging Table&r"
	quest.2CC9AF34B35FE1B5.quest_desc: [
		"Optional. The &eParticle Accelerator&r is the synchrotron multiblock — a ring of &eAccelerator Rings&r that builds up speed for endgame Oritech recipes (most importantly: &eStrange Matter&r and the &eBlack Hole Block&r)."
		""
		"Bigger rings hit higher peak energy. Inject low-tier matter and cycle it through the ring to fuse into &eStrange Matter&r."
		""
		"&7&oTip: this is one of the most space-hungry multiblocks in the pack. Build it in a flat field, not your factory.&r"
	]
	quest.2CC9AF34B35FE1B5.quest_subtitle: "Fast circles. Strange matter."
	quest.2CC9AF34B35FE1B5.title: "Particle Accelerator"
	quest.2CF735F691E0D94D.quest_desc: [
		"The &eMob Slaughter Factory&r kills mobs and produces &epink slime&r as the byproduct — the source of &ePink Slime Ingots&r used across &6IF&r recipes."
		""
		"Run it over a darkened spawn pad or feed it from a &eMob Duplicator&r. Pink slime ingots come from solidified slime balls — pipe the fluid into a solidifier (or use the &ePinkonator&r flow)."
	]
	quest.2CF735F691E0D94D.quest_subtitle: "Slaughter for slime."
	quest.2CF735F691E0D94D.title: "Mob Slaughter Factory"
	quest.2D606085832DFFE2.quest_desc: [
		"&eME Terminal&r is read-only browse; &eCrafting Terminal&r adds an inline 3×3 crafting grid that pulls from the network."
		""
		"&aPress &eG&r — &eGuideME&r → &eTerminals&r covers each variant's tradeoffs.&r"
	]
	quest.2D606085832DFFE2.quest_subtitle: "Browse and craft."
	quest.2D606085832DFFE2.title: "Terminals"
	quest.2E8FD56B289B24B1.quest_desc: ["&6Draconic Evolution&r is the modpack's late-game capstone: massive energy storage, dragon-tier weapons, and an armor set that scales linearly into the millions of FE."]
	quest.2E8FD56B289B24B1.quest_subtitle: "Wyvern → Awakened → Chaotic."
	quest.2E8FD56B289B24B1.title: "&6Draconic Evolution&r"
	quest.2ECF94A2BA25A69D.quest_desc: [
		"The &eHydroponic Bed&r grows seeded crops without farmland — the lazy alternative to &ePlant Sower&r/&eGatherer&r. Stack multiple beds for higher throughput."
		""
		"Insert a seed and pipe in &esludge&r (from the &eSludge Refiner&r) plus optional &efertilizer&r. Crops drop into the output buffer on a timer."
	]
	quest.2ECF94A2BA25A69D.quest_subtitle: "Soilless farming."
	quest.2ECF94A2BA25A69D.title: "Hydroponic Bed"
	quest.2EE00AD34E87EDBE.quest_desc: ["&6YUNG's&r turns &eMineshafts&r into biome-themed structures — desert, jungle, ice, and more, each with its own materials and inhabitants."]
	quest.2EE00AD34E87EDBE.quest_subtitle: "Mineshafts as biome-aware structures."
	quest.2EE00AD34E87EDBE.title: "&6Better Mineshafts&r"
	quest.2FEE23037DE25FAA.quest_desc: [
		"The &eEnchanter&r is &6EIO&r's flat-rate enchanting station — write a target enchantment + lapis + book and the table outputs an enchanted book at predictable XP cost. No randomness, no rerolling."
		""
		"Pick the target enchantment from the recipe browser, drop in a book + lapis, pay the listed XP. Done."
	]
	quest.2FEE23037DE25FAA.quest_subtitle: "Pick your enchant. Pay the cost."
	quest.2FEE23037DE25FAA.title: "Enchanter"
	quest.3052E3B82544C299.quest_desc: [
		"The &eME Controller&r is the heart of any AE2 network — every cable, drive, terminal, and crafting CPU connects through it. One per network."
		""
		"&aPress &eG&r anywhere to open the in-game &eGuideME&r book — every detail is there.&r"
	]
	quest.3052E3B82544C299.quest_subtitle: "Press G — read the Guide."
	quest.3052E3B82544C299.title: "ME Controller"
	quest.310133839A33645C.quest_desc: [
		"Optional. &dCoralssus&r is the coral juggernaut prowling the &eSunken City&r alongside the &dLeviathan&r — usually four or more spawn per dungeon, some locked in jail cells behind a hidden waterfall. Each kill drops a &eCoral Chunk&r, the gating ingredient for the &eAbyssal Sacrifice&r that summons the Leviathan herself."
		""
		"&aHow to acquire:&r"
		"- Find a &eSunken City&r (deep ocean) and clear the Deepling guards."
		"- Fight from a high ledge — the Coralssus's ground slams have wide AoE and stagger."
	]
	quest.310133839A33645C.quest_subtitle: "Coral chunk for the Leviathan key."
	quest.310133839A33645C.title: "Slay the &dCoralssus&r"
	quest.329EEDB0E29E970C.quest_desc: [
		"&6Industrial Foregoing&r's blender. The &eMob Crusher&r damages every mob in front of it, converting kills into drops, XP, and &bEssence&r fluid."
		""
		"Sit it over a darkened spawn pad or point it into a captive arena. &bEssence&r is liquid XP — feed it to a &6Mekanism&r &eBio-Generator&r, or convert it back into bottles for an enchanting fountain."
	]
	quest.329EEDB0E29E970C.quest_subtitle: "Mobs in, drops out."
	quest.329EEDB0E29E970C.title: "Mob Crusher"
	quest.35350AEF9EB068A5.quest_desc: [
		"&eHazmat Suit&r is non-negotiable for working a &eFission Reactor&r. The &eDosimeter&r reads your absorbed dose; the &eGeiger Counter&r reads ambient radiation around blocks and barrels."
		""
		"Equip before opening a reactor port or handling polonium pellets. A fully-modulated &eMekaSuit&r with radiation-shielding modules counts as full hazmat."
		""
		"&7&oTip: &eRadioactive Waste Barrels&r leak — store them in a sealed room and check the Geiger before entering.&r"
	]
	quest.35350AEF9EB068A5.quest_subtitle: "Don't glow in the dark."
	quest.35350AEF9EB068A5.title: "Hazmat and Dosimetry"
	quest.3555A0DA90E36994.quest_desc: [
		"&eChaotic-tier gear&r is the &6DE&r endgame — the third upgrade past Wyvern → Awakened → Chaotic. Costs &eChaos Shard&r fragments from the &dChaos Guardian&r, plus stacks of Awakened Draconium."
		""
		"The full set is the strongest non-modular armor in the pack — durability is effectively infinite as long as it stays charged."
	]
	quest.3555A0DA90E36994.quest_subtitle: "Iron's third refinement."
	quest.3555A0DA90E36994.title: "Chaotic Tier"
	quest.357893A430163C95.quest_desc: ["&6Sophisticated Storage&r and &6Sophisticated Backpacks&r share an upgrade system: pickup, magnet, filter, jukebox, XP storage. Build the iron tier of each, then upgrade as you go."]
	quest.357893A430163C95.quest_subtitle: "Storage worth looking at."
	quest.357893A430163C95.title: "&6Sophisticated&r Storage"
	quest.35A4283A659CBDE8.quest_desc: [
		"Optional. &6Create&r's signature endgame system — buildable trains routing thousands of blocks across stations and signals. The closest Minecraft will get to a real railroad."
		""
		"&aPress &eW&r — &ePonder&r is essential here. Track placement, station assembly, schedules, and signaling are all animated.&r"
	]
	quest.35A4283A659CBDE8.quest_subtitle: "Real railroads."
	quest.35A4283A659CBDE8.title: "Trains"
	quest.362C28B7B25CA3D9.quest_desc: [
		"The &eSAG Mill&r is &6EIO&r's ore grinder — ore in, dust out, up to 3× ratio with the right grinding ball. Functionally Mekanism's Crusher with a different recipe."
		""
		"Drop in a &egrinding ball&r alongside the ore — &eVibrant Alloy&r is the sweet spot for top yield with low durability cost."
	]
	quest.362C28B7B25CA3D9.quest_subtitle: "Grind. Tier. Repeat."
	quest.362C28B7B25CA3D9.title: "SAG Mill"
	quest.3690585CD331E119.quest_desc: [
		"&aWorth knowing&r — &6Ender IO&r odds and ends:"
		""
		"- &eYeta Wrench&r — rotate any EIO block, change conduit type in-place."
		"- &eVacuum Chest&r / &eXP Vacuum&r — pull dropped items / XP orbs in a radius."
		"- &eDrain&r — pulls fluid from a body of water below it."
		"- &eEnsouled Chassis&r — gives mobs custom AI / behaviors. Niche but useful."
		"- &eImpulse Hopper&r — long-range hopper that pulls/pushes across distance."
		"- &eEnergy Conduit&r tiers — basic/enhanced/ender — match throughput to demand."
		"- &eFluid Conduit&r — moves fluids; pressure-pipes for fast transit."
		"- &eDark Steel Bars&r / &eDoor&r / &eLadder&r — decorative DS variants for utility builds."
	]
	quest.3690585CD331E119.quest_subtitle: "Worth knowing — Ender IO."
	quest.3690585CD331E119.title: "Ender IO Bric-a-Brac"
	quest.36B9C4E8DE45B718.quest_desc: [
		"&dWadjet&r is the spear-wielding serpent guardian of the &eCursed Pyramid&r — a mini-boss that summons sand and lashes in close. Drops &eAncient Metal Ingots&r, the building block for &eBone Reptile&r armor and the rest of the desert-tier kit."
		""
		"&aHow to acquire:&r"
		"- Find a &eCursed Pyramid&r in any desert (or spawn-egg her in)."
		"- Stay mobile — her spear-thrusts reward backpedaling, but her sand summons punish standing still."
	]
	quest.36B9C4E8DE45B718.quest_subtitle: "Sand bites back."
	quest.36B9C4E8DE45B718.title: "Slay the &dWadjet&r"
	quest.36EA3272B9CC4D2F.quest_desc: [
		"The &eFlux Controller&r is the network's brain — install one anywhere and the network gains &awireless charging&r for any FE-accepting item on you while in range."
		""
		"One Controller per network is enough. Range and charge rate scale with how much energy the network has buffered — feed it well."
	]
	quest.36EA3272B9CC4D2F.quest_subtitle: "Wireless charging, anywhere."
	quest.36EA3272B9CC4D2F.title: "Network Controller"
	quest.380735090EE11E61.quest_desc: [
		"The &eResourceful Furnace&r smelts using &bessence&r (liquid XP) as fuel — every smelt grants you XP, and the bonus &acrushed&r effects can yield extra outputs."
		""
		"Pipe &bessence&r in from your &eMob Crusher&r setup, drop smeltables in, take ingots + XP out."
	]
	quest.380735090EE11E61.quest_subtitle: "Smelting that pays you back."
	quest.380735090EE11E61.title: "Resourceful Furnace"
	quest.387762739BB425D9.quest_desc: [
		"The &eEncased Fan&r becomes six different machines depending on what you blow through — fire smelts, water washes, smoke haunts, lava disenchants. Same block, six elements."
		""
		"&aPress &eW&r — &ePonder&r animates each processing mode and airflow rules.&r"
	]
	quest.387762739BB425D9.quest_subtitle: "Air and an idea."
	quest.387762739BB425D9.title: "Encased Fan"
	quest.38E76E428BB53F52.quest_desc: [
		"What was a smolder is now a held flame. The Core is no longer sleepy — it's waiting."
		""
		"Refine the &eEmber&r in iron to forge the &eSpark&r."
	]
	quest.38E76E428BB53F52.quest_subtitle: "The fire holds."
	quest.38E76E428BB53F52.title: "Tier 3 - &eSpark of the Titan&r"
	quest.38F95A1627AB4B54.quest_desc: [
		"&6Ender IO&r's &eStirling Generator&r is a no-frills coal burner — drop it, feed it, wire it. Simple, but it unlocks the entire EIO alloy progression."
		""
		"Tap power off any face with an &aenergy conduit&r and feed it &ecoal&r, &echarcoal&r, or any burnable for steady &bFE/t&r."
	]
	quest.38F95A1627AB4B54.quest_subtitle: "Old-school combustion, modern alloys."
	quest.38F95A1627AB4B54.title: "Stirling Cycle"
	quest.39B1C4D5E6F70801.quest_desc: [
		"&6Apotheosis&r's &eReforging Table&r re-rolls the &aaffixes&r on a piece of affixed loot. Hand it junk gear, get back a fresh roll — sometimes better, sometimes worse."
		""
		"Reforging burns &eSigils of Rebirth&r plus rarity materials of the item's tier. The reward &eSigil of Enhancement&r feeds the &eAugmenting Table&r — a separate station for upgrading or rerolling a single &aaffix&r at a time."
		""
		"&7&oTip: rare-tier gear is rolled by the Reforging Table, but high-tier loot needs Epic or Mythic materials — stockpile before you commit.&r"
	]
	quest.39B1C4D5E6F70801.quest_subtitle: "Re-roll the dice."
	quest.39B1C4D5E6F70801.title: "&6Apotheosis&r: Forge Reforge"
	quest.39B1C4D5E6F70810.quest_desc: [
		"&6Apothic Enchanting&r replaces vanilla bookshelves with biome-flavored shelves that push &aenchanting&r past level 30 by raising the &aEterna&r, &aQuanta&r, and &aArcana&r stats at the table."
		""
		"Surround your enchanting table with the Hellshelf, Endshelf, and any other Apothic shelves you can craft. A full Apothic library opens up enchantments stronger than vanilla can offer."
	]
	quest.39B1C4D5E6F70810.quest_subtitle: "Past level 30."
	quest.39B1C4D5E6F70810.title: "&6Apothic Enchanting&r: Beyond Vanilla"
	quest.39B1C4D5E6F70820.quest_desc: [
		"&6Mekanism&r's &eAtomic Disassembler&r is a single FE-powered tool that acts as pickaxe, axe, shovel, sword, and hoe at once. Built-in modes include vein-mining and a 3×3 area break."
		""
		"Charge it on any FE-output device. Hold the mode key to cycle between vein, extended, and standard. Frees up four hotbar slots in the process."
	]
	quest.39B1C4D5E6F70820.quest_subtitle: "One tool to rule them all."
	quest.39B1C4D5E6F70820.title: "&6Mekanism&r: &eAtomic Disassembler&r"
	quest.39B2C3D4E5F60710.quest_desc: [
		"&6Ars Nouveau&r's &eSorceror's&r set is the entry-tier robe loadout — light armor with mana cost reduction and &bSource&r regeneration when worn together."
		""
		"Wear the full set for the regen and cost-reduction set bonus — partial sets give you nothing."
	]
	quest.39B2C3D4E5F60710.quest_subtitle: "Dress for casting."
	quest.39B2C3D4E5F60710.title: "Mage Robes"
	quest.39B370551F08C5F2.quest_desc: [
		"&6Create&r's logistics fabric — items glide along belts, funnels insert/extract from blocks at either end. &eAndesite Funnel&r is the basic tier; &eBrass Funnel&r adds filtering."
		""
		"&aPress &eW&r — &ePonder&r covers belt directions, funnel modes, and tunnel splitting.&r"
	]
	quest.39B370551F08C5F2.quest_subtitle: "The conveyor stack."
	quest.39B370551F08C5F2.title: "Belt and Funnel"
	quest.3CE304364DB0BBC0.quest_desc: [
		"&aWorth knowing&r — the &6Mekanism&r odds and ends that don't get their own quest but you'll want anyway:"
		""
		"- &eCardboard Box&r — wraps a placed machine, picks it up, settings preserved. Move your factory without rebuilding."
		"- &eConfigurator&r — wrench. Side-config tabs, multiblock validity, color picker for cables."
		"- &eConfiguration Card&r — copy-paste a machine's full config to another machine of the same type."
		"- &eGauge Dropper&r — siphons a tiny amount of any fluid/gas from a tank. Use it to bottle one bucket of a fluid for JEI lookups."
		"- &eRobit&r — your portable storage pet. Place a Personal Chest, name a Robit, never lose your inventory again."
		"- &eSeismic Reader&r + &eSeismic Vibrator&r — full-column ore scan above-and-below the machine."
		"- &eFormulaic Assemblicator&r — automatic crafter that holds a recipe template and crafts on a redstone tick."
		"- &eMekanism Laser&r + &eLaser Amplifier&r + &eLaser Tractor Beam&r — high-energy beam blocks. Useful for Fusion ignition, or for the spectacle."
	]
	quest.3CE304364DB0BBC0.quest_subtitle: "Worth knowing — Mekanism."
	quest.3CE304364DB0BBC0.title: "Mekanism Bric-a-Brac"
	quest.3D13647AEFF0943F.quest_desc: [
		"The &eWixie Cauldron&r is &6Ars Nouveau&r's potion factory. Pair the cauldron with a &eWixie&r familiar bound to it, plus a &ePotion Jar&r for storage, and you have automated potion brewing."
		""
		"Configure the cauldron's recipe; the Wixie fetches ingredients and brews; jars capture and re-issue the result."
	]
	quest.3D13647AEFF0943F.quest_subtitle: "Potions on autopilot."
	quest.3D13647AEFF0943F.title: "Wixie Cauldron"
	quest.3D147F708192A582.quest_desc: [
		"&6Mekanism&r's &eMekaSuit&r is the modular endgame armor set — four pieces, each a slotted shell. Bare shells are unremarkable; the &aModules&r are what make the set absurd: night vision, gravity stabilizer, magnet, jetpack, radiation shielding, and more."
		""
		"Build a &eModification Station&r alongside the suit — that's where modules slot in. Modules are crafted separately from a &eModule Base&r plus the relevant ingredients. Mode-key cycles active modules in flight."
		""
		"&aHeadline modules:&r"
		"- &aJetpack module&r (chestplate) — full vertical flight."
		"- &aRadiation shielding&r (full set) — required for late-game Mek work."
		"- &aThermal regulator&r — passive fire/cold resistance."
	]
	quest.3D147F708192A582.quest_subtitle: "Four pieces. The modules come next."
	quest.3D147F708192A582.title: "&6Mekanism&r: &eMekaSuit Armor Set&r"
	quest.3DC23BD54B670DE8.quest_desc: ["&6YUNG's&r redesigned &eStronghold&r layouts — atmospheric, themed by region, with the End portal still at the end."]
	quest.3DC23BD54B670DE8.quest_subtitle: "Abandoned. Reclaimed. Yours next."
	quest.3DC23BD54B670DE8.title: "&6Better Strongholds&r"
	quest.3F9A0E334404046A.quest_desc: [
		"&6Mekanism&r's &eJetpack&r burns &bhydrogen&r for vertical thrust — three modes: hover, normal, and disabled. The cleanest mid-game flight in the pack until you reach Wyvern-tier."
		""
		"Hydrogen comes off an &eElectrolytic Separator&r fed water. Equip the jetpack in the chestplate slot, hold &ejump&r to thrust, mode-toggle key cycles hover/normal/off. Refuel by piping &bhydrogen&r in or hand-filling from a &eHydrogen Tank&r."
	]
	quest.3F9A0E334404046A.quest_subtitle: "Hover, ascend, glide."
	quest.3F9A0E334404046A.title: "&6Mekanism&r: &eJetpack&r"
	quest.3FA2174F63B06F5E.quest_desc: [
		"&eStarbuncle&r is the item-courier familiar — summon it with a &eStarbuncle Charm&r, then link source and destination with a &eDominion Wand&r (right-click source, sneak-right-click destination). The Starbuncle shuttles loose drops home."
		""
		"Multiple Starbuncles run parallel pickups."
	]
	quest.3FA2174F63B06F5E.quest_subtitle: "A pet that picks up after you."
	quest.3FA2174F63B06F5E.title: "Starbuncle Logistics"
	quest.4096E7F031E43727.quest_desc: [
		"&eTravel Anchor&r is the line-of-sight teleport beacon — look at one within 64 blocks and right-click to jump. The &eStaff of Travelling&r extends the range to 256 and works on any block."
		""
		"The Staff also right-clicks blocks at range for remote interaction — useful for hitting buttons or levers across a chasm."
	]
	quest.4096E7F031E43727.quest_subtitle: "Look. Click. Teleport."
	quest.4096E7F031E43727.title: "Travel Anchors"
	quest.420C49B55F5DA985.quest_desc: [
		"&6Mekanism&r's &eHeat Generator&r is the cheapest entry into a full Mekanism setup — the simplest source of &aForge Energy&r in the mod's tech tree."
		""
		"Drop in &elava buckets&r, &echarcoal&r, or any furnace fuel and tap power off the back with a &eUniversal Cable&r. Adjacent &blava source blocks&r boost output passively."
		""
		"&7&oTip: a Heat Generator with lava on every side runs hotter than one in open air. Pipe lava in adjacent, not into the fuel slot.&r"
	]
	quest.420C49B55F5DA985.quest_subtitle: "Industry, in a single block."
	quest.420C49B55F5DA985.title: "Industrial Heat"
	quest.42D24546E6A1331F.quest_desc: [
		"&6Mekanism&r ships four signal types, each with their own pipe:"
		""
		"- &eUniversal Cable&r — &aForge Energy&r"
		"- &eMechanical Pipe&r — fluids"
		"- &ePressurized Tube&r — gases (&boxygen&r, &bhydrogen&r, &bsulfuric acid&r, &bantimatter&r)"
		"- &eThermodynamic Conductor&r — heat between Boilers, Reactors, and Turbines"
		""
		"Each tier (&eBasic&r → &eAdvanced&r → &eElite&r → &eUltimate&r) bumps throughput. Right-click any segment with a &eConfigurator&r to change its connection mode (push, pull, none)."
	]
	quest.42D24546E6A1331F.quest_subtitle: "Power, fluids, gases, heat."
	quest.42D24546E6A1331F.title: "Universal Transport"
	quest.44576A594B9EF3C1.quest_desc: [
		"&6Ars Nouveau&r's &arituals&r are area-of-effect magic — bind animals, awaken trees, conjure weather. Place a &eRitual Brazier&r in an area appropriate to the ritual's effect, drop a tablet (e.g. &eRitual of Awakening&r animates nearby trees into walking guardians), then ignite with flint and steel to fire it."
		""
		"&7&oTip: the brazier needs to be lit with flint and steel — placing the tablet alone won't trigger anything.&r"
	]
	quest.44576A594B9EF3C1.quest_subtitle: "Sacred geometry made manifest."
	quest.44576A594B9EF3C1.title: "First Ritual"
	quest.44637BCFE916C1DA.quest_desc: [
		"&6Create&r's foundational kinetic source. The &eWater Wheel&r runs on flowing water around its perimeter; the &eLarge Water Wheel&r is a 3×3 multiblock that scales the output. &eHand Crank&r and &eWindmill Bearing&r round out the early-game options."
		""
		"&aPress &eW&r — &ePonder&r covers placement, water-flow patterns, and stress capacity per source.&r"
	]
	quest.44637BCFE916C1DA.quest_subtitle: "Water in. Rotation out."
	quest.44637BCFE916C1DA.title: "Water Wheel"
	quest.44C930116CD8D934.quest_desc: [
		"&6Mekanism&r's &eMetallurgic Infuser&r is the alloy crafter — feed it iron + carbon to make &eEnriched Iron&r, then iron + Enriched Iron to make &eSteel&r. Steel gates &eSteel Casing&r, which gates every machine in the chapter."
		""
		"Carbon comes from coal or charcoal dust enriched at the &eEnrichment Chamber&r. The full path: iron + carbon → &eEnriched Iron&r; iron + Enriched Iron → &eEnriched Alloy&r → smelt to &eSteel&r."
	]
	quest.44C930116CD8D934.quest_subtitle: "Steel and circuits start here."
	quest.44C930116CD8D934.title: "Metallurgic Infuser"
	quest.45495B1CC43D1C41.quest_desc: [
		"&eAwakened Draconium&r is the post-Chaos-Guardian alloy — &eDraconium Ingot&r charged inside an active &eEnergy Core&r field becomes &eAwakened Draconium Ingot&r, the gateway to Chaotic-tier gear and the Reactor."
		""
		"Drop ingots into the field and let them charge over time. The output feeds the &eAwakened Core&r recipe and Chaotic-tier gear crafting."
	]
	quest.45495B1CC43D1C41.quest_subtitle: "Charge the metal."
	quest.45495B1CC43D1C41.title: "Awakened Draconium"
	quest.4734A3D951B268D1.quest_desc: [
		"&eFlux Points&r are the output side. Pair one with a Plug somewhere on the same network and energy starts moving — across any distance, any dimension."
		""
		"Place the Point against the machine you want to power, open its GUI, assign it to the matching network, and tune its rate and priority."
	]
	quest.4734A3D951B268D1.quest_subtitle: "Push power into a machine."
	quest.4734A3D951B268D1.title: "Wireless Point"
	quest.477C3C2BE9118B1F.quest_desc: [
		"&eCursium&r is the ghost-themed armor tier — only &dMaledictus&r (the Ender Guardian) drops the &eCursium Smithing Template&r and the ingots needed. The full set is one of the strongest in the pack: Ghost Vision on the helmet, Undead Revive on the chestplate (resurrects you once on death), Ghost Dodge on the leggings, and a back-step on the boots."
		""
		"&aHow to craft:&r each piece is a &esmithing table&r upgrade — &eCursium Smithing Template&r + the matching &enetherite&r piece + &eCursium Ingots&r. Same shape as netherite-from-diamond, one tier higher."
		""
		"&7&oTip: the &eUndead Revive&r chestplate effect locks you out for six minutes after firing — don't burn it on chip damage.&r"
	]
	quest.477C3C2BE9118B1F.quest_subtitle: "Ghost armor, four pieces."
	quest.477C3C2BE9118B1F.title: "Cursium Set"
	quest.47D51C4D8FED1723.quest_desc: ["&6Industrial Foregoing&r's farming pair. The &ePlant Sower&r plants a 3×3 area below it; the &ePlant Gatherer&r harvests a 3×3 area in front of it. Pipe seeds in, pipe crops out, feed both &aForge Energy&r."]
	quest.47D51C4D8FED1723.quest_subtitle: "A farm that runs itself."
	quest.47D51C4D8FED1723.title: "Plant Sower Gatherer"
	quest.47E8A5AEDC9156BB.quest_desc: [
		"Even with all the modded glitter, vanilla's three big locations still matter: the &dNether&r, the &dEnd&r, and the first &eStronghold&r."
		""
		"Visit each."
	]
	quest.47E8A5AEDC9156BB.quest_subtitle: "The classic checklist."
	quest.47E8A5AEDC9156BB.title: "Vanilla Milestones"
	quest.489168A85C1C3C1F.quest_desc: [
		"Every &6Mekanism&r machine has an &eUpgrades&r slot — drop these in (up to 8 per machine) for stat boosts:"
		""
		"- &eSpeed&r — faster processing, more &bFE&r per tick"
		"- &eEnergy&r — bigger internal FE buffer, lower per-op cost"
		"- &eMuffling&r — silence the machine"
		"- &eAnchor&r — chunk-load the block"
		"- &eFilter&r &7(Logistical Sorter / Separator)&r — bias outputs"
		"- &eGas&r &7(specific machines)&r — extends internal gas-tank capacity"
		""
		"Crafted from &eInfused Alloy&r, cheap glass, and an upgrade-specific core (osmium dust for Speed, gold for Energy, diamond for Anchor, and so on). &eSpeed + Energy&r stacked is the standard 'make this machine cheap and fast' combo."
	]
	quest.489168A85C1C3C1F.quest_subtitle: "Drop them in. Watch the stats."
	quest.489168A85C1C3C1F.title: "Machine Upgrades"
	quest.49F8246885175A10.quest_desc: [
		"&eSigils&r are &6Apotheosis&r's consumable utility tools — &eWithdrawal&r removes a single affix and saves it on a vial; &eExtraction&r vial pulls an affix off and stores it for transplant; &eUnnaming&r removes a forced custom name."
		""
		"Right-click gear with a held vial to peel an affix off, then apply that vial to another piece of gear to transplant. Powerful for moving a roll you love onto better base gear."
	]
	quest.49F8246885175A10.quest_subtitle: "Peel and transplant affixes."
	quest.49F8246885175A10.title: "Sigils and Vials"
	quest.4A1B2C3D4E5F6071.quest_desc: [
		"A heartbeat forms inside the Spark. The Core's hum syncs to your footsteps when you stand close."
		""
		"Add copper to the &eSpark&r to draw the &ePulse&r."
		""
		"&aWorld Tier:&r completing this quest advances you to &eAscent&r. Epic affixes start appearing and elite mobs get a noticeable damage bump."
	]
	quest.4A1B2C3D4E5F6071.quest_subtitle: "It has a heartbeat now."
	quest.4A1B2C3D4E5F6071.title: "Tier 4 - &ePulse of the Titan&r"
	quest.4AC2D5E6F708B900.quest_desc: [
		"&6Tool Belt&r adds a waist-slot accessory that holds extra tools and lets you swap them into your main hand with a scroll-wheel gesture. Frees the hotbar for blocks and food."
		""
		"Equip via the Curios slot menu (default key &er&r). Hold the bind-key (default &ez&r) and scroll to swap which tool lands in hand."
	]
	quest.4AC2D5E6F708B900.quest_subtitle: "Strap your tools to your waist."
	quest.4AC2D5E6F708B900.title: "&6Tool Belt&r"
	quest.4B17DC52A06091AE.quest_desc: [
		"&6Building Wands&r adds wands that bulk-place blocks. Aim at a face, click, and the wand extends the surface along your line of sight, drawing from your inventory."
		""
		"Five tiers — &eStone&r (16/swing) → &eCopper&r → &eIron&r (32) → &eDiamond&r (64) → &eNetherite&r (256). Modes for rows, fills, grids, lines, circles, and copy/paste."
		""
		"&7&oTip: keep a &eShulker Box&r stocked — wands pull from it before your hotbar.&r"
	]
	quest.4B17DC52A06091AE.quest_subtitle: "Right-click to extend a face."
	quest.4B17DC52A06091AE.title: "&6Building Wands&r"
	quest.4C6CF541318C7436.quest_desc: [
		"&6Apotheosis&r's &eGem Cutting Table&r turns &eGem Dust&r (crushed from gems you don't want) plus rarity materials into upgraded &egems&r. Sockets in your gear are only as strong as the gem you slot."
		""
		"Drop a gem and the listed reagents into the table to combine or upgrade."
	]
	quest.4C6CF541318C7436.quest_subtitle: "Crush, recombine, upgrade."
	quest.4C6CF541318C7436.title: "&6Apotheosis&r: &eGem Cutting&r"
	quest.4C7CBCCF0634848D.quest_desc: [
		"&6Create&r's automated crafting multiblock. Arrange &eMechanical Crafters&r in the shape of the recipe — each holds one ingredient slot — point them at a single output cell, and pulse them with kinetic stress."
		""
		"&aPress &eW&r — &ePonder&r animates crafter arrangement, slot facing, and output direction. Required reading.&r"
	]
	quest.4C7CBCCF0634848D.quest_subtitle: "Recipe shaped in blocks."
	quest.4C7CBCCF0634848D.title: "Mechanical Crafter"
	quest.4E258071829B6A93.quest_desc: [
		"&6Create&r's &eDiving Helmet&r plus a &eCopper Backtank&r let you breathe underwater for as long as the tank's pressure holds. Equip both pieces and the tank auto-feeds the helmet — re-pressurise before any deep dive or lava swim."
		""
		"Refill the tank with a &eMechanical Pump&r piping &bair&r in, or walk around for a slow trickle. Combine each piece with a Netherite Upgrade at a Smithing Table to reach the lava-proof tier."
		""
		"&aPress &eW&r — &ePonder&r covers backtank pressurisation and helmet wiring.&r"
	]
	quest.4E258071829B6A93.quest_subtitle: "Breathe underwater. Survive lava."
	quest.4E258071829B6A93.title: "&6Create&r: &eDiving Gear&r"
	quest.4E4BE2A3440BB0F0.quest_desc: [
		"&6Createaddition&r's &eTesla Coil&r is the high-voltage zap — wirelessly charges in-range FE-accepting items (Mek Jetpack refuel, charged tools). The &eModular Accumulator&r is its battery; stack multiples to expand the buffer."
		""
		"&aPress &eW&r — &ePonder&r covers Coil range, charging rules, and Accumulator stacking.&r"
	]
	quest.4E4BE2A3440BB0F0.quest_subtitle: "Sparks fly. Batteries fill."
	quest.4E4BE2A3440BB0F0.title: "Tesla Coil and Accumulator"
	quest.4E85CEF3E40170CF.quest_desc: [
		"&6Oritech&r's endgame shaper. The &dAtomic Forge&r transmutes elements at the atomic level — the gateway to &bFluxite&r-tier crafts."
		""
		"Power-hungry. Run it from a Mekanism Energy Cube or a Draconic capacitor."
	]
	quest.4E85CEF3E40170CF.quest_subtitle: "Endgame transmutation."
	quest.4E85CEF3E40170CF.title: "&dAtomic Forge&r"
	quest.4EB9BF26C58A6193.quest_desc: [
		"The &eSupercritical Phase Shifter&r turns &bpolonium&r into &bantimatter pellets&r — the most concentrated currency in Mekanism. Each pellet is the price of admission to the late MekaSuit module catalog."
		""
		"Polonium comes off your fission waste line. Feed it in, hand the supercharged coil massive FE, and pellets drop out. Outside the Titan Core itself, the SPS is the most power-hungry block in the pack."
	]
	quest.4EB9BF26C58A6193.quest_subtitle: "Polonium in. Antimatter out."
	quest.4EB9BF26C58A6193.title: "Supercritical Phase Shifter"
	quest.516A9483A90FD357.quest_desc: ["&6Ender IO&r is the conduit-and-capacitor mod: shared conduits for energy/items/fluids, alloys that climb a clear tier ladder, and lazy-farmer machines like the &eFarming Station&r."]
	quest.516A9483A90FD357.quest_subtitle: "Alloys, capacitors, conduits, and a base that runs itself."
	quest.516A9483A90FD357.title: "&6Ender IO&r"
	quest.52384D0B09D5E630.quest_desc: [
		"Optional. The &eDraconic Reactor&r is &6DE&r's nuclear-class FE generator — output rivals a &eMekanism Fusion Reactor&r at the cost of substantially more dangerous setup."
		""
		"Insert &eAwakened Draconium&r as fuel and tune the containment field carefully — runaway temperature ends in a chunk-deleting explosion."
		""
		"&7&oTip: a deep FE buffer is non-optional. Without one, the Reactor's startup pulse will pop your network.&r"
	]
	quest.52384D0B09D5E630.quest_subtitle: "Don't blow up your base."
	quest.52384D0B09D5E630.title: "Draconic Reactor"
	quest.52758F4E624A6440.quest_desc: [
		"&6Ars Nouveau&r's &eScribe's Table&r inscribes &aglyphs&r from XP and &bSource&r. The &eMage's Spell Book&r is what you cast them from — together they are the combat and utility kernel."
		""
		"Drop spell parchment on the Scribe's Table to inscribe a &aglyph&r, then bind glyphs into the spell book and cast."
	]
	quest.52758F4E624A6440.quest_subtitle: "Inscribe a glyph. Cast it."
	quest.52758F4E624A6440.title: "Inscribe Cast"
	quest.52858BE17389BA11.quest_desc: ["&6Oritech&r is a fresh take on tech: bio generators, biosteel, and a pulverizer/centrifuge/assembler progression. Lighter than Mekanism, denser than vanilla."]
	quest.52858BE17389BA11.quest_subtitle: "A newer tech mod with cleaner lines."
	quest.52858BE17389BA11.title: "&6Oritech&r"
	quest.53A654BDD709AEBB.quest_desc: [
		"&6Createaddition&r's &eAlternator&r turns &6Create&r rotational force into &aForge Energy&r. The bridge from kinetic builds to FE-hungry machines."
		""
		"&aPress &eW&r — &ePonder&r covers RPM thresholds and the FE-output curve.&r"
	]
	quest.53A654BDD709AEBB.quest_subtitle: "Rotation, refined into electricity."
	quest.53A654BDD709AEBB.title: "Kinetic Conversion"
	quest.5601821AEEF30E39.quest_desc: [
		"The &eFusion Reactor&r is the optional capstone — a self-sustaining D-T fusion chamber that, once running, makes the Fission Reactor look quaint."
		""
		"Ignition needs a charged &eHohlraum&r and a &eLaser Amplifier&r dumping 400MFE into it. One ignition is enough as long as deuterium + tritium keep feeding in. Output is in the gigaFE/t range — pair it with antimatter for the SPS."
		""
		"&7&oTip: this quest is &eoptional&r. Pursue Fusion for the engineering and the antimatter feedstock.&r"
	]
	quest.5601821AEEF30E39.quest_subtitle: "The cleanest path to absurd."
	quest.5601821AEEF30E39.title: "Fusion Reactor"
	quest.56C3E73F7256EF9A.quest_desc: [
		"&aWorth knowing&r — AE2 odds and ends:"
		""
		"- &eFluix Glass Cable&r — basic, cheap, 32 channels (pack runs &eX4&r capacity)."
		"- &eFluix Covered Cable&r — same channels, opaque, looks cleaner."
		"- &eFluix Smart Cable&r — visualizes channel routing on its surface."
		"- &eFluix Dense Cable&r — 128 channels, color-coded."
		"- &eP2P Tunnels&r — long-distance bridges between two endpoints (FE, items, fluids)."
		"- &eGrowth Accelerator&r — speeds up nearby budding certus quartz."
		"- &eAnnihilation Plane&r / &eFormation Plane&r — break / place blocks at the network's edge."
		"- &eSky Stone Chest&r — encountered at meteor crash sites; loot the press inside."
		""
		"&aPress &eG&r — &eGuideME&r is the manual. Better than any quest line.&r"
	]
	quest.56C3E73F7256EF9A.quest_subtitle: "Worth knowing — AE2."
	quest.56C3E73F7256EF9A.title: "AE2 Bric-a-Brac"
	quest.5826EC6A328C5DE5.quest_desc: ["&6Mekanism&r is the modpack's deepest tech tree: ore-multiplication, six tiers of factory machines, fission/fusion power, and the &eMekaSuit&r that makes you obsolete the rest of your gear."]
	quest.5826EC6A328C5DE5.quest_subtitle: "Energy. Processing. Suit. Pick a path."
	quest.5826EC6A328C5DE5.title: "&6Mekanism&r"
	quest.583149F56A45EEC4.quest_desc: [
		"&6Item Collectors&r places a block that vacuums up loose items in a configurable radius and pushes them into adjacent inventories."
		""
		"Sit it above or beside the chest you want fed. Adjust range from the GUI; toggle range visualisation to verify coverage."
	]
	quest.583149F56A45EEC4.quest_subtitle: "Drops, vacuumed."
	quest.583149F56A45EEC4.title: "&6Item Collectors&r"
	quest.58B750E7ABF5DF0B.quest_desc: [
		"The &eDeployer&r holds a tool or item and uses it on the block in front — like a placed player. Right-click logic, attack logic, sequential crafting if you slot ingredients."
		""
		"&aPress &eW&r — &ePonder&r walks tool slotting, mob/tree farms, and inline crafting.&r"
	]
	quest.58B750E7ABF5DF0B.quest_subtitle: "A hand on a stick."
	quest.58B750E7ABF5DF0B.title: "Deployer"
	quest.5917A928B0BDAD22.quest_desc: [
		"&eCapacitor Banks&r are EIO's batteries — placeable, configurable, scaleable. Adjacent banks of the same tier merge into a multiblock automatically and share FE."
		""
		"Right-click to open and configure I/O per-side. The &eVibrant&r tier holds much more per block than &eBasic&r — worth the upgrade once your network needs the headroom."
	]
	quest.5917A928B0BDAD22.quest_subtitle: "Stack to scale."
	quest.5917A928B0BDAD22.title: "Capacitor Banks"
	quest.5988DF86EAF5244F.quest_desc: [
		"&ePattern Provider&r feeds patterns into machines; &ePattern Encoding Terminal&r is where you write the patterns. Together: AE2 autocrafts any recipe you've encoded."
		""
		"&aPress &eG&r — &eGuideME&r → &ePatterns&r is the canonical reference.&r"
	]
	quest.5988DF86EAF5244F.quest_subtitle: "Encode. Provide. Craft."
	quest.5988DF86EAF5244F.title: "Patterns/Providers"
	quest.5A1B2C3D4E5F6071.quest_desc: [
		"The Pulse calls back. Faint whispers in old tongues drift from the projection."
		""
		"Run the &ePulse&r through gold to call the &eEcho&r."
	]
	quest.5A1B2C3D4E5F6071.quest_subtitle: "It speaks back."
	quest.5A1B2C3D4E5F6071.title: "Tier 5 - &eEcho of the Titan&r"
	quest.5B3CAE4F906D7B20.quest_desc: [
		"&6Mekanism&r's processing chain multiplies ore yield up to &a5×&r. Each machine in the line is one rung up:"
		""
		"- &eEnrichment Chamber&r &7(2× — ore to dust)&r"
		"- &eCrusher&r &7(supports the 3× dust→shards path)&r"
		"- &ePurification Chamber&r &7(4× — needs &bOxygen&r)&r"
		"- &eChemical Injection Chamber&r &7(5× — needs &bHydrogen Chloride&r)&r"
		""
		"Running the full chain is a commitment to &6Mekanism&r's mid-game — every tier above 3× wants its own chemical infrastructure feeding it."
	]
	quest.5B3CAE4F906D7B20.quest_subtitle: "Five times the ore. The full chain."
	quest.5B3CAE4F906D7B20.title: "Quintuple Down"
	quest.5BD3E6F708192A01.quest_desc: [
		"&6Mekanism&r's &eSolar Generator&r is silent, fuelless, and roof-mountable. Output per panel is modest — these shine when you tile a roof with them and bus the output through &eUniversal Cables&r."
		""
		"Generation only runs in daylight with clear sky overhead. Pair the array with an &eEnergy Cube&r for the night reserve."
	]
	quest.5BD3E6F708192A01.quest_subtitle: "Free FE, forever."
	quest.5BD3E6F708192A01.title: "Solar Array"
	quest.5BD3E6F708192A10.quest_desc: [
		"&6Ender IO&r's &ePhotovoltaic Modules&r are roof-tile generators. The &eEnergetic&r tier is mid-output; the &eVibrant&r tier roughly doubles it."
		""
		"Modules placed in a flat grid auto-share output through their bottom face. Wire one corner with an &aenergy conduit&r and the whole array drains into your network."
	]
	quest.5BD3E6F708192A10.quest_subtitle: "Tile the roof. Watch it pour."
	quest.5BD3E6F708192A10.title: "Photovoltaic"
	quest.5BD3E6F708192A20.quest_desc: [
		"&6Mekanism&r's &eGas-Burning Generator&r runs on combustible gases. &bEthene&r is the canonical mid-tier feedstock, made by piping &bBio Fuel&r (from a Bio Generator) and &bHydrogen&r (from an Electrolytic Separator) into a &ePressurized Reaction Chamber&r."
		""
		"Run the resulting &bEthene&r into the generator with a &ePressurized Tube&r and the FE flows."
	]
	quest.5BD3E6F708192A20.quest_subtitle: "Pipe in the gas. Watch the FE pour."
	quest.5BD3E6F708192A20.title: "Gas-Burning Generator"
	quest.5BD3E6F708192A30.quest_desc: [
		"&6Create&r's mid-game power tier. Boil water in a stack of &eFluid Tanks&r heated by &eblaze burners&r, then tap rotational force off &eSteam Engines&r mounted on the boiler's sides."
		""
		"&aPress &eW&r — &ePonder&r walks the boiler multiblock, steam tiers, and engine placement.&r"
	]
	quest.5BD3E6F708192A30.quest_subtitle: "Boil. Spin. Power."
	quest.5BD3E6F708192A30.title: "Steam Engine"
	quest.5BD3E6F708192A40.quest_desc: [
		"&6Industrial Foregoing&r's &eBioreactor&r accepts almost any plant matter — saplings, seeds, crops, mushrooms — and converts it into &bBiofuel&r. Variety in the input slots boosts efficiency; nine distinct items hits the &b1440 mB/cycle&r ceiling. The &eBiofuel Generator&r burns the output straight into &aForge Energy&r."
		""
		"&7&oTip: nine different inputs, one of each — that's the recipe for the cap. Stacking 64 wheat into one slot does almost nothing.&r"
	]
	quest.5BD3E6F708192A40.quest_subtitle: "Plants in. Power out."
	quest.5BD3E6F708192A40.title: "Living Fuel"
	quest.5BD3E6F708192A50.quest_desc: [
		"&6Oritech&r's &eBio Generator&r is the mod's introductory power tier — feed it &eBiomass&r (centrifuged from organic items at an Oritech Centrifuge) and it churns out steady &bFE&r at low cost."
		""
		"Pull &aForge Energy&r off any face with an Oritech &acable&r."
	]
	quest.5BD3E6F708192A50.quest_subtitle: "Centrifuge what you grow. Burn what comes out."
	quest.5BD3E6F708192A50.title: "Biomass Burner"
	quest.5BD3E6F708192A60.quest_desc: [
		"&6Draconic Evolution&r's &eWyvern Capacitor&r is the entry-tier portable battery — millions of &bFE&r in a hand-held cell, slottable into any FE-using tool. Capacitors are the backbone of late-game gear charge."
		""
		"Charge it from any &aFE source&r and slot it into compatible Draconic tools and armor for an instant capacity bump."
	]
	quest.5BD3E6F708192A60.quest_subtitle: "Storage at draconium scale."
	quest.5BD3E6F708192A60.title: "Wyvern's Battery"
	quest.5BD3E6F708192A70.quest_desc: [
		"&eFlux Plugs&r are the input side of the wireless grid — place one against a generator's output face and energy flows into the &6Flux Network&r."
		""
		"Open the Plug's GUI and assign it to a network (create one on the spot if needed). Power leaves the generator immediately, but won't reach anything until you also place a &ePoint&r."
	]
	quest.5BD3E6F708192A70.quest_subtitle: "Pull power off a generator."
	quest.5BD3E6F708192A70.title: "Wireless Plug"
	quest.5BD3E6F708A0CA10.quest_desc: [
		"&6Mining Gadgets&r' &eMining Gadget MK1&r is a powered laser pick that breaks blocks in a configurable area — flat tunnels, big rooms, surgical clear-outs."
		""
		"Right-click to mine; sneak-right-click to change the area shape and size. Slot &aupgrade modules&r at the &eModification Table&r (silk, fortune, magnet, void-junk, light, etc.) to tune the behavior."
	]
	quest.5BD3E6F708A0CA10.quest_subtitle: "Tunnel without the pickaxe."
	quest.5BD3E6F708A0CA10.title: "&6Mining Gadgets&r: &eMining Gadget&r"
	quest.5D3BC110998474C4.quest_desc: [
		"&aWorth knowing&r — &6Oritech&r odds and ends:"
		""
		"- &eWrench&r — rotates and pickup-with-config any Oritech machine."
		"- &eEnergy Pipe&r / &eFluid Pipe&r / &eItem Pipe&r — Oritech's color-coded pipe system. Connect machines without conduit clutter."
		"- &eEnchanter Block&r — Oritech's powered enchanter; fast and reliable."
		"- &eAtomic Augment Station&r — applies augments (passives) to gear."
		"- &eCharger Block&r — surface-mount FE charger for tools."
		"- &eBanana&r — Oritech's joke fruit. Yes, it's a real item."
	]
	quest.5D3BC110998474C4.quest_subtitle: "Worth knowing — Oritech."
	quest.5D3BC110998474C4.title: "Oritech Bric-a-Brac"
	quest.5D4A02AEFDC74408.quest_desc: [
		"The &eMolecular Assembler&r is the block that turns &eEncoded Patterns&r into items. A &ePattern Provider&r pushes ingredients into an adjacent Assembler and the result lands back on the network — that's how every autocrafting recipe in &6AE2&r physically happens."
		""
		"Stack Assemblers around a Pattern Provider's faces to parallelise crafts. For high-throughput setups, &6Extended AE2&r's &eEx Pattern Provider&r (granted as the reward) handles many more pattern slots and feeds Assembler walls without the channel cost of vanilla providers."
		""
		"&aPress &eG&r — &eGuideME&r → &eAutocrafting&r covers pattern encoding, processing patterns, and Assembler placement.&r"
	]
	quest.5D4A02AEFDC74408.quest_subtitle: "Patterns become items here."
	quest.5D4A02AEFDC74408.title: "Molecular Assembler"
	quest.5DE11EF5D664F8E7.quest_desc: [
		"There are three handheld scanners. Each one has its own in-game tooltip describing how it works — hover over it in your inventory to read it."
		""
		"The lists below cover what each finder targets and its scan range."
		""
		"&aGem Finder:&r"
		"- Targets &bdiamond, emerald, lapis, nether quartz, fluorite&r and modded gems (&bruby, sapphire, topaz&r, etc.)"
		"- Range: 12 horizontal, 64 vertical"
		""
		"&aMetal Finder:&r"
		"- Targets &biron, copper, gold, ancient debris&r and modded metals (&btin, osmium, uranium, lead, zinc, nickel, platinum&r, etc.)"
		"- Range: 16 horizontal, 96 vertical"
		"- &7The workhorse for tier progression.&r"
		""
		"&aMineral Finder:&r"
		"- Targets &bcoal&r and &bredstone&r."
		"- Range: 14 horizontal, 80 vertical"
		""
		"Each finder has &edurability 4&r — they wear out after a handful of uses, so save them for surveying large areas."
	]
	quest.5DE11EF5D664F8E7.title: "Pocket Surveyors"
	quest.5E85D1B027D7F049.quest_desc: [
		"&6Oritech&r machines accept &eAddon Blocks&r — speed, capacity, range, yield. Each slot stacks; a &eMachine Extender&r doubles the addon count for a machine."
		""
		"Right-click a machine to open its addon GUI. Higher addon tiers ramp throughput dramatically — the same machine can do up to 10× its base rate when fully kitted."
	]
	quest.5E85D1B027D7F049.quest_subtitle: "Stack the upgrades."
	quest.5E85D1B027D7F049.title: "Machine Addons"
	quest.5F36918293A07BA4.quest_desc: [
		"&6Draconic Evolution&r's Wyvern is the mid-tier — the rung you climb before challenging the &dChaos Guardian&r. The &eWyvern Chestpiece&r tanks an absurd amount of damage; the &eWyvern Sword&r cleaves through anything pre-Mythic."
		""
		"Slot &eEnergy Cores&r into the chestpiece to fuel damage absorption and unlock flight. Keep the sword charged from any FE source — its energy buffer fuels the damage scaling."
	]
	quest.5F36918293A07BA4.quest_subtitle: "Mid-tier draconic. Chaos still ahead."
	quest.5F36918293A07BA4.title: "&6Draconic Evolution&r: Wyvern-tier"
	quest.6063BA7EDC6B39E8.quest_desc: [
		"The &ePowered Spawner&r is &6EIO&r's mob factory — right-click an empty &eSoul Vial&r on the target mob to capture, drop the filled vial in, supply power. Pair with a damage source (lava, magma, Mekanism Laser, Mob Crusher) for an FE-fed loot farm."
		""
		"&7&oTip: harder mobs cost more FE per spawn — wither skeletons aren't free.&r"
	]
	quest.6063BA7EDC6B39E8.quest_subtitle: "Capture. Spawn. Loot."
	quest.6063BA7EDC6B39E8.title: "Powered Spawner"
	quest.60AC7B83914DEF52.quest_desc: [
		"&6Cataclysm&r's &eIgnitium&r set is the fire-themed armor tier — drops &dIgnis&r and his Nether territory yield the &eIgnitium Smithing Template&r and the ingots needed to forge it."
		""
		"&aHow to craft:&r each piece is a &esmithing table&r upgrade — &eIgnitium Smithing Template&r + the matching &enetherite&r piece + &eIgnitium Ingots&r. Same shape as netherite-from-diamond, one tier higher."
		""
		"&aSet bonuses:&r"
		"- &aGaze of Heat&r (helmet) — apply Blazing Brand to enemies."
		"- &aFlame Reflex&r (leggings) and &aLava Walker&r (boots) round out the set."
		"- &aChestplate&r combines with elytra for fireproof flight."
	]
	quest.60AC7B83914DEF52.quest_subtitle: "Forged in Ignis-fire."
	quest.60AC7B83914DEF52.title: "&6Cataclysm&r — &eIgnitium Set&r"
	quest.610AC7347A4F7705.quest_desc: ["The mods that don't justify their own chapter still earn a spot. This chapter clusters every smaller mod into its own little section — adventure, storage, decor, food, logistics, and so on."]
	quest.610AC7347A4F7705.quest_subtitle: "Smaller mods, organized by mod."
	quest.610AC7347A4F7705.title: "&bOther&r"
	quest.618A9A4F484C7964.quest_desc: [
		"The &eBookwyrm Lectern&r partners with a &eBookwyrm&r familiar to automate &eGlyph&r crafting at your &eScribes Table&r. Saves a lot of late-game spellcrafting drudgery."
		""
		"Place the lectern next to the Scribes Table; the Bookwyrm pulls glyph ingredients from nearby chests and scribes them automatically. Frees you to design spells without copy-paste runs."
	]
	quest.618A9A4F484C7964.quest_subtitle: "A scribe, hired."
	quest.618A9A4F484C7964.title: "Bookwyrm Lectern"
	quest.6277D2C336D1242B.quest_desc: [
		"AE2's interface points: &eImport Bus&r pulls in, &eExport Bus&r pushes out, &eStorage Bus&r treats an external inventory as part of the network, &eInterface&r is a portable pattern target."
		""
		"&aPress &eG&r — &eGuideME&r → &eBuses&r explains every variant.&r"
	]
	quest.6277D2C336D1242B.quest_subtitle: "Pull, push, expose."
	quest.6277D2C336D1242B.title: "Buses/Interfaces"
	quest.62898E68F9F7515D.quest_desc: ["&6YUNG's&r reimagined &eDesert Temples&r have multi-room layouts, traps, and significantly better loot. Find one and explore."]
	quest.62898E68F9F7515D.quest_subtitle: "More than a sand pyramid with a hole."
	quest.62898E68F9F7515D.title: "&6Better Desert Temples&r"
	quest.633C74689327AB2C.quest_desc: [
		"&6AE2&r is dense, but it hides nothing. The mod ships with its own searchable in-game guide, and that's how this pack expects you to learn it."
		""
		"Hover any &6AE2&r item or block in your inventory and press the &aOpen Guide&r key (default &eG&r). The Guide opens directly to that item's page — recipes, mechanics, and the full picture of how channels, cables, and storage fit together."
		""
		"{@pagebreak}"
		"Skim it once. Come back when you have a specific question. Don't try to memorize it."
		""
		"&aPack tweak:&r channel capacity is set to &eX4&r — &eFluix Glass&r / &eCovered&r carry &e32&r, &eDense&r carries &e128&r. The Guide's numbers are stock; multiply by 4."
		""
		"&aAlso bundled:&r &6Extended AE2&r adds higher-tier crafting CPUs, infinity-class storage cells, and beefier pattern providers. Same Guide key (&eG&r) covers its blocks too — they slot into a vanilla AE2 network without ceremony."
	]
	quest.633C74689327AB2C.quest_subtitle: "Hold G. The mod tells you the rest."
	quest.633C74689327AB2C.title: "&6AE2&r: Read the Guide"
	quest.63F8356A56A27467.quest_desc: [
		"Optional. The &eSchematicannon&r builds &6Create&r-saved structures one block at a time, pulling materials from a chest beside it. Iconic Create UX, more creative-mode toy than survival tool."
		""
		"&aPress &eW&r — &ePonder&r covers schematic capture, loading, and aim mechanics.&r"
	]
	quest.63F8356A56A27467.quest_subtitle: "Cannon-build your blueprints."
	quest.63F8356A56A27467.title: "Schematicannon"
	quest.66505E73698CDE6E.quest_desc: ["&6Ars Nouveau&r is the pack's only magic mod — a fully-featured spellcrafting system with sourcelinks, ritual brazier, sorcerer armor, and pet-class familiars."]
	quest.66505E73698CDE6E.quest_subtitle: "Source. Spells. Rituals. Familiars."
	quest.66505E73698CDE6E.title: "&6Ars Nouveau&r"
	quest.66964241AA24DB82.quest_desc: [
		"Optional. The &eDrone Port&r is &6Oritech&r's wireless logistics — a docking station for drones that fetch items from a remote chest and deliver them home."
		""
		"Place a port at each end (home and remote source), configure the route in the GUI, and the drone shuttles items on schedule. No cabling required."
	]
	quest.66964241AA24DB82.quest_subtitle: "Wireless cargo."
	quest.66964241AA24DB82.title: "Drone Port"
	quest.66F047CA2BA01C46.quest_desc: [
		"Powered handhelds — &eHand Drill&r breaks blocks like a vanilla pickaxe but FE-fueled and faster; &eChainsaw&r is its tree-felling counterpart."
		""
		"Charge them in any &eCharger Block&r or carry a battery. Speed scales with charge — a full battery is peak break rate, a near-empty one stalls."
	]
	quest.66F047CA2BA01C46.quest_subtitle: "Power tools."
	quest.66F047CA2BA01C46.title: "Hand Tools"
	quest.677D49D729D0A833.quest_desc: ["&6Apotheosis&r layers an entire RPG system on top of vanilla: gem cutting, reforging, affixed mobs, boss summoners, and the world-tier scaling that defines the pack's combat curve."]
	quest.677D49D729D0A833.quest_subtitle: "Cut. Reforge. Salvage. Socket."
	quest.677D49D729D0A833.title: "&6Apotheosis&r"
	quest.67DD832356EFB488.quest_desc: [
		"&6Oritech&r's mid-tier shapers. The &eAssembler&r runs templated multi-block recipes; the &eFragment Forge&r breaks items down into raw fragments for re-use."
		""
		"Collect Assembler templates as you progress — each one unlocks a new recipe in the same machine."
	]
	quest.67DD832356EFB488.quest_subtitle: "Frames out. Fragments in."
	quest.67DD832356EFB488.title: "Mid-Tier Crafting"
	quest.68414A50EFFAFAE0.quest_desc: [
		"The &eAntiprotonic Nucleosynthesizer&r is the antimatter-fed crafting altar — one ingredient + one &ePellet of Antimatter&r yields the upgraded variant. Diamond → emerald, iron → gold, charcoal → coal, etc., plus exclusive recipes for late-game Mek components."
		""
		"&7&oNote: &eAtomic Alloy&r (gating the MekaSuit) is craftable here at lower cost than the standard recipe.&r"
	]
	quest.68414A50EFFAFAE0.quest_subtitle: "Antimatter as a reagent."
	quest.68414A50EFFAFAE0.title: "Antiprotonic Nucleosynthesizer"
	quest.69A4948CDD9B5881.quest_desc: [
		"&6Createaddition&r's &eElectric Motor&r is the reverse of the &eAlternator&r — feed it &aForge Energy&r, get rotation. The bridge from FE-rich late-game systems back into the &6Create&r kinetic network."
		""
		"&aPress &eW&r — &ePonder&r covers FE input, RPM tuning via redstone, and shaft output direction.&r"
	]
	quest.69A4948CDD9B5881.quest_subtitle: "FE in. Rotation out."
	quest.69A4948CDD9B5881.title: "Electric Motor"
	quest.6A1B2C3D4E5F6071.quest_desc: [
		"The Echo gains intent. The titan-shape above the Core no longer rotates passively — it watches."
		""
		"Bulk-craft the &eEcho&r in diamond to bind the &eWill&r."
		""
		"&aWorld Tier:&r completing this quest advances you to &eSummit&r. Mythic affixes enter the pool and the world starts treating you as a serious threat."
	]
	quest.6A1B2C3D4E5F6071.quest_subtitle: "It wants something."
	quest.6A1B2C3D4E5F6071.title: "Tier 6 - &eWill of the Titan&r"
	quest.6C4DBF50A17E8C30.quest_desc: [
		"&6Create&r's identity pair. The &eMechanical Press&r flattens ingots into sheets; the &eMechanical Mixer&r combines fluids and items in a &eBasin&r. Together they birth every Brass Ingot in the pack."
		""
		"&aPress &eW&r — &ePonder&r animates each recipe and the basin-stacking trick.&r"
	]
	quest.6C4DBF50A17E8C30.quest_subtitle: "Press, mix, repeat."
	quest.6C4DBF50A17E8C30.title: "Pressing Matters"
	quest.6C7DFBA1B6392A8A.quest_desc: [
		"&6Hostile Neural Networks&r teaches your computer to dream of monsters. Tag a mob with the &eDeep Learner&r, train its &eData Model&r in the &eSim Chamber&r, and the &eLoot Fabricator&r turns &ePredictions&r back into drops — no spawn pad, no AFK, no risk."
		""
		"Both machines chew through &bFE&r. Undersize the line and the loop stalls."
	]
	quest.6C7DFBA1B6392A8A.quest_subtitle: "Loot without combat."
	quest.6C7DFBA1B6392A8A.title: "&6Hostile Neural Networks&r"
	quest.6C918370046EF26C.quest_desc: ["&6YUNG's&r ground-up redesign of the &eJungle Temple&r — multi-floor, trapped, and built with serious loot in mind."]
	quest.6C918370046EF26C.quest_subtitle: "Indiana Jones could cry."
	quest.6C918370046EF26C.title: "&6Better Jungle Temples&r"
	quest.6CE4F5061728390A.quest_desc: [
		"&6Farmer's Delight&r rebuilds vanilla cooking around real kitchen tools — &eCooking Pot&r for stews and curries (needs a heat source below), &eSkillet&r for pan-fried meat (atop a campfire or held), &eCutting Board&r + &eKnife&r for ingredient prep."
		""
		"Drop ingredients into the Cooking Pot's slots; finished meals collect in the output buffer."
	]
	quest.6CE4F5061728390A.quest_subtitle: "Cook like you mean it."
	quest.6CE4F5061728390A.title: "&6Hot Kitchen&r"
	quest.6CE4F5061728391A.quest_desc: ["&6Supplementaries&r adds dozens of decorative-but-useful blocks. &eSacks&r store items, &eGlobes&r spin, &eHourglasses&r tick — small things that make a base feel lived-in."]
	quest.6CE4F5061728391A.quest_subtitle: "The little things."
	quest.6CE4F5061728391A.title: "&6Worldly Trinkets&r"
	quest.6CE4F5061728392A.quest_desc: ["&6Quark&r is a grab bag of tweaks. The &eTrowel&r places random blocks from your inventory; the &eBackpack&r adds an inventory row; small touches across the board."]
	quest.6CE4F5061728392A.quest_subtitle: "Vanilla, with sharper edges."
	quest.6CE4F5061728392A.title: "&6Pocket Tools&r"
	quest.6CE4F5061728393A.quest_desc: [
		"&6Sophisticated Storage&r barrels and chests scale by tier — stone, copper, iron, gold, diamond, netherite. Each tier increases slot count and adds &aupgrade&r slots (stack, magnet, pickup, smelting, compacting). Apply tier-up kits to upgrade an existing barrel in place — contents are preserved."
		""
		"&7&oTip: link the Controller to storages with the Storage Tool, then place Storage Connectors to bridge gaps in the multiblock.&r"
	]
	quest.6CE4F5061728393A.quest_subtitle: "Tiered barrels and chests with upgrade slots."
	quest.6CE4F5061728393A.title: "&6Sophisticated Storage&r"
	quest.6CE4F5061728394A.quest_desc: [
		"&6Pipez&r is the simple-but-fast item / fluid / energy / gas logistics solution."
		""
		"Right-click an end of the pipe to open the upgrade GUI; transfer rate scales with the upgrade tier slotted in. The same chassis handles fluid, energy, and gas — swap the pipe variant, same upgrades fit."
	]
	quest.6CE4F5061728394A.quest_subtitle: "Move stuff. Quickly."
	quest.6CE4F5061728394A.title: "&6Pipework&r"
	quest.6CE4F5061728395A.quest_desc: [
		"&6Functional Storage&r drawers are compact, &anetworked&r item silos — link them with the &eLinking Tool&r, control the network from anywhere, slot in upgrades to scale capacity."
		""
		"Right-click a drawer with the item you want stored to lock it to that type. Use the &eLinking Tool&r to add drawers to a &eStorage Controller&r, then slot &eCopper&r/&eIron&r/&eGold&r/&eDiamond&r upgrades for capacity multipliers."
	]
	quest.6CE4F5061728395A.quest_subtitle: "Compact, networked drawers."
	quest.6CE4F5061728395A.title: "&6Functional Storage&r"
	quest.6CE4F5061728396A.quest_desc: [
		"&6Simple Magnets&r are exactly what they sound like — equip one in your &aCurios&r belt slot and it pulls items and XP toward you within a configurable radius."
		""
		"Craft and equip the &eBasic Magnet&r."
	]
	quest.6CE4F5061728396A.quest_subtitle: "Items come to you."
	quest.6CE4F5061728396A.title: "&6Equip a Magnet&r"
	quest.6CE4F5061728397A.quest_desc: [
		"&6CC: Tweaked&r drops Lua-programmable computers into Minecraft. The &eComputer&r is the brain — text terminal, persistent filesystem, full programming environment."
		""
		"Right-click the Computer to open the terminal; type &elua&r or &eedit <file>&r to start scripting. Label a &eDisk&r in a Disk Drive to share programs between machines."
		""
		"&7Note: &eTurtles&r are disabled in this pack — automated mining is off-limits by design. Computers, monitors, modems, and peripherals all stay craftable.&r"
	]
	quest.6CE4F5061728397A.quest_subtitle: "Code in your world."
	quest.6CE4F5061728397A.title: "&6Boot a Computer&r"
	quest.6CFBF73AA4473B0D.quest_desc: [
		"&6Flux Networks&r is wireless &aForge Energy&r distribution. Build a network of &ePlugs&r (input from generators) and &ePoints&r (output to machines), tied together by a &eFlux Controller&r that scales globally and crosses dimensions."
		""
		"Stop running cables. Start running networks."
	]
	quest.6CFBF73AA4473B0D.quest_subtitle: "No wires. Anywhere. Any dimension."
	quest.6CFBF73AA4473B0D.title: "&6Flux Networks&r"
	quest.6DAE34EEAC47FACF.quest_desc: [
		"&6Apotheosis&r's &eAugmenting Table&r is the surgical tool — re-roll a single &aaffix&r on a piece of gear without touching the others. Burns &eSigils of Enhancement&r and rarity materials per try."
		""
		"&7&oTip: keep your favorite affixes locked, augment only the bad ones — much cheaper than full reforges.&r"
	]
	quest.6DAE34EEAC47FACF.quest_subtitle: "Surgical re-rolls."
	quest.6DAE34EEAC47FACF.title: "Augmenting Table"
	quest.6DD6993615585377.quest_desc: [
		"The &eFission Reactor&r is Mekanism's nuclear power plant — a multiblock that converts &eFissile Fuel&r into massive heat, fed into a &eBoiler&r + &eTurbine&r for &aMega-FE/t&r output."
		""
		"Insert &eFissile Fuel&r (depleted uranium + plutonium pellets) and pump in coolant — sodium for high-temp builds, water for low-temp. &c⚠&r &eRadioactive Waste Barrels&r catch the polonium output; siphon it for the SPS."
		""
		"&7&oTip: SCRAM means &lemergency shutdown&r — wire a redstone signal so you can pull the rods if temperature runs away. Meltdowns are real and they delete chunks.&r"
	]
	quest.6DD6993615585377.quest_subtitle: "Atomic, with all the warnings."
	quest.6DD6993615585377.title: "Fission Reactor"
	quest.6EB796D2C3E0061C.quest_desc: ["&6YUNG's&r expanded &eOcean Monuments&r are massive — bring water-breathing potions, Depth Strider boots, and patience."]
	quest.6EB796D2C3E0061C.quest_subtitle: "Atlantis, drowned and dangerous."
	quest.6EB796D2C3E0061C.title: "&6Better Ocean Monuments&r"
	quest.6FA84BEEE0BB88B0.quest_desc: [
		"&dThe Prowler&r is a robotic mini-boss buried in the &eAncient Factory&r — the same structure that hides the &dHarbinger&r. It hunts you with a spinning saw and homing missiles."
		""
		"&aHow to acquire:&r"
		"- Find an &eAncient Factory&r (rare Overworld dungeon, locate with an &eEye of Mech&r)."
		"- Stay close — at range you eat missiles; in melee you only deal with the saw."
	]
	quest.6FA84BEEE0BB88B0.quest_subtitle: "Saw and missile."
	quest.6FA84BEEE0BB88B0.title: "Slay the &dProwler&r"
	quest.714690D48088A02F.quest_desc: [
		"The &a5× ore route&r — Mekanism's deepest ore-multiplication chain. Each ore becomes 5 ingots if you walk it through every stage."
		""
		"The new machines plug into your existing line: &eChemical Dissolution Chamber&r (ore + sulfuric acid → slurry) → &eChemical Washer&r (clean slurry) → &eChemical Crystallizer&r (5 crystals per ore)."
		""
		"From there, crystals run back through the standard chain — Injection Chamber → 5 shards → Purification → 5 clumps → Crusher → 5 dirty dust → Enrichment → 5 dust → Smelter → 5 ingots."
		""
		"&7&oTip: this is the canonical Mekanism endgame chain — set it up once on every important ore (iron, gold, copper, osmium) and never look at vanilla mining again.&r"
	]
	quest.714690D48088A02F.quest_subtitle: "One ore in. Five ingots out."
	quest.714690D48088A02F.title: "5x Ore Processing"
	quest.71BD8C9402EFA063.quest_desc: [
		"&6Apotheosis&r affixes roll on weapons in five rarity tiers: Common, Uncommon, Rare, Epic, and &dMythic&r. Mythic-tier rolls are the apex — multi-affix, dramatic stat bonuses, often with a unique mechanic."
		""
		"&aHow to find one:&r"
		"- Kill bosses (vanilla, Apoth, Cataclysm) at &aSummit&r tier or higher — drop tables include affix loot."
		"- Combine lower-tier items at the &eSalvaging Table&r → &eGem Cutting Table&r → &eAugmenting Table&r chain to roll up."
		"- The drop here is a &eGodforged Pearl&r — the rarest material in Apoth, used to craft Mythic-tier sigils."
		""
		"&aTask:&r submit one &eGodforged Pearl&r as proof you reached the deep loot tables."
		""
		"&7&oTip: drop rate scales with World Tier — push your tier first.&r"
	]
	quest.71BD8C9402EFA063.quest_subtitle: "Apex of the affix table."
	quest.71BD8C9402EFA063.title: "&6Apotheosis&r — &dMythic Trophy&r"
	quest.73122F6E402575EA.quest_desc: [
		"Nine &6YUNG's Better X&r mods replace the dull vanilla generation of dungeons, temples, fortresses, and monuments with hand-crafted variants — bigger, more dangerous, more rewarding."
		""
		"Visit one of each kind to clear this section. They generate naturally; explore widely or check &6JourneyMap&r waypoints when you find them."
	]
	quest.73122F6E402575EA.quest_subtitle: "Vanilla structures, scaled up."
	quest.73122F6E402575EA.title: "&6YUNG's Better Structures&r"
	quest.74ED5B05FC10AF83.quest_desc: [
		"The Heart of the Titan beats above the world. The projection is no longer a projection — it stands."
		""
		"Forge the &eBreath&r in netherite — the &eHeart&r beats."
	]
	quest.74ED5B05FC10AF83.quest_subtitle: "Apotheosis."
	quest.74ED5B05FC10AF83.title: "Tier 10 - &eHeart of the Titan&r"
	quest.75534119CD098FE9.quest_desc: [
		"&eDark Steel&r is &6EIO&r's premier alloy — armor and tools that scale through repair-anvil upgrades. Dark steel ingots smelt at the Alloy Smelter (obsidian + iron + coal); the helmet, chestplate, and pickaxe are all worth pursuing alongside the sword."
		""
		"Apply &eUpgrades&r at an anvil — speed, vampirism, depth, etc. Each upgrade costs raw alloy + XP, so DS gear scales smoothly through mid-game."
	]
	quest.75534119CD098FE9.quest_subtitle: "Iron with attitude."
	quest.75534119CD098FE9.title: "Dark Steel Smithing"
	quest.7637512874BE9397.quest_desc: [
		"&6Sophisticated Backpacks&r adds tiered backpacks with slotted upgrades — pickup, magnet, filter, compaction, crafting, and more. The &eIron Backpack&r is the second tier and the first one with enough upgrade slots to matter."
		""
		"Each tier wraps the previous — leather → copper → iron at the crafting table. Wear in the chest slot or place as a block to access remotely. Slot pickup/magnet/filter upgrades to stop hoovering up trash."
	]
	quest.7637512874BE9397.quest_subtitle: "Carry it all."
	quest.7637512874BE9397.title: "&6Sophisticated Backpacks&r"
	quest.7914E88D15989240.quest_desc: [
		"Optional. The &eWither Builder&r places the wither summon arrangement (4 soul sand, 3 wither skulls) automatically when given the materials and a redstone pulse. Combined with a &eMob Crusher&r facing the spawn spot, it's a fully automated nether-star farm."
		""
		"Pipe in the soul sand + skulls, pulse redstone, the builder assembles the wither and your kill source handles the rest."
		""
		"&7&oTip: do this in a contained box. The wither's spawn explosion will eat your factory if you don't.&r"
	]
	quest.7914E88D15989240.quest_subtitle: "Star factory."
	quest.7914E88D15989240.title: "Wither Builder"
	quest.7988F41C45712714.quest_desc: ["The classic gateway. Every tech and magic mod has dependencies that route through &dNether&r materials."]
	quest.7988F41C45712714.quest_subtitle: "The first portal."
	quest.7988F41C45712714.title: "Visit &dthe Nether&r"
	quest.79E232C1900191CD.quest_desc: [
		"Two of &6Cataclysm&r's mid-to-late metals. &eWitherite&r drops only from the &dHarbinger&r in the &eAncient Factory&r — it gates the wither-themed shoulder cannons and the &eMechanical Fusion Anvil&r. &eBlack Steel&r drops from the &eDraugr&r and &eAptrgangr&r elites in the &eFrosted Prison&r and forges into a clean tool tier-up from netherite."
		""
		"Hold the Witherite for the &eWither Assault Shoulder Weapon&r and other Harbinger-only crafts."
	]
	quest.79E232C1900191CD.quest_subtitle: "Two prisons, two metals."
	quest.79E232C1900191CD.title: "Witherite and Black Steel"
	quest.7A1B2C3D4E5F6071.quest_desc: [
		"The Will speaks in clean, terrible Latin. Mobs nearby flinch when the projection inhales."
		""
		"Push the &eWill&r through more diamond to give it a &eVoice&r."
	]
	quest.7A1B2C3D4E5F6071.quest_subtitle: "It commands."
	quest.7A1B2C3D4E5F6071.title: "Tier 7 - &eVoice of the Titan&r"
	quest.7A39D5FCDB67F252.quest_desc: ["The &eCombiner&r reverses the &eCrusher&r — dust/raw + cobble in, raw ore out. Useful for converting fluid-tin/copper output back into placeable ore for visual builds, but its real value is producing &edense ores&r for stacking."]
	quest.7A39D5FCDB67F252.quest_subtitle: "Press dust back into ore."
	quest.7A39D5FCDB67F252.title: "Combiner"
	quest.7A7119BD0237EFD2.quest_desc: [
		"&eCrafting CPUs&r are AE2's autocrafting cores — assembled from &eCrafting Unit&r, &eAccelerator&r, &eStorage&r, and &eMonitor&r blocks. More accelerators = parallel crafts."
		""
		"&aPress &eG&r — &eGuideME&r → &eAutocrafting&r walks the multi-block layout.&r"
	]
	quest.7A7119BD0237EFD2.quest_subtitle: "Build the brain."
	quest.7A7119BD0237EFD2.title: "Crafting CPU"
	quest.7B76FC0AD1E5D11A.quest_desc: [
		"&eExo Armor&r is &6Oritech&r's powered tech-armor set — four pieces, FE-charged, with a chestplate-mounted &eJetpack&r upgrade slot for vertical mobility."
		""
		"Wear the full set and charge from any FE source. The &eJetpack Elytra&r upgrade unlocks Elytra-style glide once you've found a vanilla Elytra to slot in."
	]
	quest.7B76FC0AD1E5D11A.quest_subtitle: "Powered armor. Build the pieces."
	quest.7B76FC0AD1E5D11A.title: "Exo Armor"
	quest.7B8E873125E72915.quest_desc: [
		"&eIndustrial Turbine&r + &eThermoelectric Boiler&r is the steam-cycle endgame for Mekanism — multiblock, scaleable, and producing &aMega-FE/t&r at full size."
		""
		"Pump heated water into the boiler; route the resulting steam into the turbine. Pair with a &eFuelwood Heater&r for early steam, or feed it &eFission Reactor&r heat for endgame output. The &eMekanism Configurator&r scans your multiblock for validity."
	]
	quest.7B8E873125E72915.quest_subtitle: "Steam, scaled to ridiculous."
	quest.7B8E873125E72915.title: "Boiler and Turbine"
	quest.7BE305D05A99BFC1.quest_desc: [
		"&bSource&r is mana. The &eVolcanic Sourcelink&r generates it from heat (lava, fire, blazing things nearby), &eSource Relays&r transport it line-of-sight, and a &eSource Jar&r stores the buffer."
		""
		"Bind components together with the &eDominion Wand&r — sneak-right-click the source, then right-click the target."
	]
	quest.7BE305D05A99BFC1.quest_subtitle: "Generate, transport, store."
	quest.7BE305D05A99BFC1.title: "Mana on Tap"
	quest.7D5EC061B28F9D50.quest_desc: [
		"&6Create&r's heavyweight ore doubler. Two wheels face each other spinning in opposite directions; ore drops through the seam and grinds into crushed-ore. No per-recipe tweaking — they chew anything kinetic-grindable."
		""
		"&aPress &eW&r — &ePonder&r covers the rotation pairing and feed mechanics.&r"
	]
	quest.7D5EC061B28F9D50.quest_subtitle: "Drop ore. Get more ore."
	quest.7D5EC061B28F9D50.title: "Crushing Wheels"
	quest.7D8F1A84CAEE2B73.quest_desc: [
		"&6Metal Barrels&r are straight tier-ups of the vanilla barrel — copper, iron, silver, gold, diamond, obsidian, netherite, crystal. Each tier multiplies stack size dramatically."
		""
		"Same right-click interface as any barrel — capacity is the only thing that changes. Apply an upgrade item (e.g. &eIron To Diamond&r) to bump an existing barrel without breaking it."
	]
	quest.7D8F1A84CAEE2B73.quest_subtitle: "The vanilla barrel, scaled hard."
	quest.7D8F1A84CAEE2B73.title: "&6Metal Barrels&r"
	quest.7DA79533AFA8AAEB.quest_desc: [
		"Ores in this pack don't generate the way they do in vanilla."
		""
		"Vanilla scatters small veins everywhere — a few iron blocks here, a few there. Project Titan replaces that with &6AdLods&r: each ore type generates as a rare &emotherlode deposit&r — hundreds to thousands of blocks in one place — instead of many tiny scatters."
		""
		"You won't trip over ore by accident. You'll either &bsearch&r for it or you'll be carrying a finder (next quest)."
		""
		"&aFlower indicators:&r above each deposit, a circular ring of flowers blooms on the surface. Different ores grow different flower combinations. Below is an &eiron deposit&r — orange tulips inside, azure bluets outside."
		""
		"{image:kubejs:textures/quests/ore_flowers.png width:300 height:237 fit:true align:center}"
		""
		"A few ores share signatures, but a flower ring on the surface always means &esomething is buried below&r. Dig down to confirm."
	]
	quest.7DA79533AFA8AAEB.quest_subtitle: "Ore deposits, not ore veins."
	quest.7DA79533AFA8AAEB.title: "Reading the Earth"
	quest.7DD4046D89B7B4D9.quest_desc: [
		"&aWorth knowing&r — &6Apotheosis&r odds and ends:"
		""
		"- &ePotion Charm&r — equip in a curio slot to keep a potion effect always-on, drawing from a stack."
		"- &eLucky Foot&r — equip-slot trinket; raises drop quality."
		"- &eMusic Discs&r (Flash, Glimmer, Shimmer) — boss drops from Apotheosis arenas."
		"- &eGem Case&r / &eEnder Gem Case&r — sortable storage for gem stockpiles."
		"- &eSimple Reforging Table&r — cheaper, slower variant of the regular Reforging Table."
		"- &eSigil of Malice&r — re-rolls an item's drop chance modifier downward (rare-use)."
		"- &eDiamond/Iron/Gold Smithing Templates&r — netherite-style upgrades from Apotheosis."
	]
	quest.7DD4046D89B7B4D9.quest_subtitle: "Worth knowing — Apotheosis."
	quest.7DD4046D89B7B4D9.title: "Apotheosis Bric-a-Brac"
	quest.7E52C89DD2E004DD.quest_desc: [
		"&6Ender IO&r's signature transport block. One item — &eConduit&r — that becomes whichever type you place first. Tiers and signal types:"
		""
		"- &eEnergy&r → &eEnergetic&r → &eVibrant&r &7(FE throughput tiers)&r"
		"- &eItem&r → &eEnergetic&r → &eVibrant&r &7(items, with filtering on each end)&r"
		"- &eFluid&r → &eEnergetic&r &7(pressurized)&r → &eVibrant&r"
		"- &eRedstone&r &7(signal-only, single tier)&r"
		""
		"Right-click placed conduit with a &eYeta Wrench&r to cycle connection modes (in / out / disabled). Multiple conduit types can occupy the same block — packed pipework in one item slot."
	]
	quest.7E52C89DD2E004DD.quest_subtitle: "One block. Every signal."
	quest.7E52C89DD2E004DD.title: "Conduits"
	quest.7E66E335AD1D9D15.quest_desc: ["&6YUNG's&r rebuilds &eNether Fortresses&r as proper layered architecture — multi-level halls, chambers, and tougher inhabitants."]
	quest.7E66E335AD1D9D15.quest_subtitle: "Now with bridges that lead somewhere."
	quest.7E66E335AD1D9D15.title: "&6Better Nether Fortresses&r"
	quest.7EA222DBC1855F7B.quest_desc: [
		"&6Draconic Evolution&r's &eEnergy Core&r is the modpack's deepest FE buffer — a tiered crystal at the center of a stabilized field; capacity scales aggressively with tier."
		""
		"Place the core, ring it with at least four &eEnergy Core Stabilizers&r in the field directions, and use &eEnergy Pylons&r as the I/O ports tying it to your network. Higher tiers demand more Awakened Draconium."
	]
	quest.7EA222DBC1855F7B.quest_subtitle: "FE buffer at scale."
	quest.7EA222DBC1855F7B.title: "Energy Core"
	quest.7F2435C222DBAB7B.quest_desc: [
		"&6Oritech&r ships its own spawner system — toss a &eSpawner Cage&r at a mob to capture it, then drop the filled cage into a &eSpawner Controller&r and supply FE. Mobs spawn on a timer."
		""
		"&7&oTip: pair with a Mob Crusher (Industrial Foregoing) or Killer Joe-style setup for an XP/loot farm.&r"
	]
	quest.7F2435C222DBAB7B.quest_subtitle: "Catch. Cage. Power. Repeat."
	quest.7F2435C222DBAB7B.title: "Spawner Cages"
	quest.7FEE2AF45B268424.quest_desc: [
		"Optional. &eSpatial IO&r lets you snapshot a region into a &eSpatial Storage Cell&r — temporary pocket dimension on demand. Niche but iconic."
		""
		"&aPress &eG&r — &eGuideME&r → &eSpatial&r is non-trivial. Read it before building.&r"
	]
	quest.7FEE2AF45B268424.quest_subtitle: "Pocket dimensions."
	quest.7FEE2AF45B268424.title: "Spatial IO"
	quest.7FF43E7A6CEDAB1A.quest_desc: [
		"The &eLaser Arm&r is &6Oritech&r's remote-fire automation — right-click a target with the &eTarget Designator&r, then point the arm; it locks on."
		""
		"Depending on configuration it charges machines, beam-mines designated blocks, or zaps mobs at range."
	]
	quest.7FF43E7A6CEDAB1A.quest_subtitle: "Aim. Charge. Zap."
	quest.7FF43E7A6CEDAB1A.title: "Laser Arm"
	task.3D147F708192A583.title: "MekaSuit Helmet"
	task.3D147F708192A588.title: "MekaSuit Bodyarmor"
	task.3D147F708192A589.title: "MekaSuit Pants"
	task.3D147F708192A58A.title: "MekaSuit Boots"
	task.4C6BBF235F620A3F.title: "ASddff"
	task.4F512AB1304BED9A.title: "Accept the Titan's challenge"
	task.60AC7B83914DEF57.title: "Ignitium Helmet"
	task.60AC7B83914DEF58.title: "Ignitium Chestplate"
	task.6B2C8D4F5E3A7081.title: "Choose a Path"
	task.6DB905F59BD03A72.title: "Visit Nether"
	chapter.37A6C9E1284B5D0F.title: "Start"
	chapter.7106E7A1B10FA010.title: "Stage 1-2: Basic Power"
	chapter.7106E7A1B10FA020.title: "Stage 3-4: Steel Factory"
	chapter.7106E7A1B10FA030.title: "Stage 5-6: Fluids and Chemistry"
	chapter.7106E7A1B10FA040.title: "Stage 7-8: Advanced Power"
	chapter.7106E7A1B10FA050.title: "Logistics and Transport"
	chapter.7106E7A1B10FA060.title: "Affix Forge"
	chapter_group.7106E7A1B10FA000.title: "RNGTech"
	quest.01C84F033E61813D.quest_desc: ["Battery with the highest burst capabilities"]
	quest.0511A72AEC9FAB27.quest_desc: [
		"&eTin&r is the second half of the first bronze lesson."
		""
		"&aBuild:&r"
		"- Collect a &eTin Ingot&r."
		""
		"&aUse:&r"
		"- Crush tin when the Stage 3 bronze path asks for dust."
		"- Treat Tin as an alloy ingredient first, not as a full machine stage."
	]
	quest.0511A72AEC9FAB27.quest_subtitle: "The alloy partner for copper."
	quest.0511A72AEC9FAB27.title: "First Tin"
	quest.055FAC8A7D35E178.quest_desc: ["Check the Affixes questline chapter"]
	quest.06CF355466851823.quest_desc: [
		"Combine Tin Dust and Copper Dust to create your first Alloy"
		""
		"&aCraft:&r"
		"- Combine 3 copper dust with 1 tin dust"
		"- Smelt Bronze Dust in Furnace"
	]
	quest.06CF355466851823.title: "First Alloy"
	quest.09E6CC376427E6D3.quest_desc: [
		"Got a bunch of unused components/gear. Setup a manual recycling station"
		""
		""
		"&eCraft&r"
		"- Crude Recycler"
		"- Hand Crank"
		""
		""
		"&eBuild&r"
		"Place the &bhand crank&r on top of the &bcrude recycler&r"
	]
	quest.09EAFEBDB30A3137.quest_desc: ["A bit too conductive for it's own good. It leaks energy if sitting idle. Go with iron if you prefer a more stable battery"]
	quest.1003E61C2B6F8611.quest_desc: ["Always a good idea to keep your tools relevant. Go ahead and create iron variants of the 3 heavy tools"]
	quest.10D59A7D9BDC28C1.quest_desc: [
		"Mining companion is a utility item with limited functionality"
		"- Can chew blocks, e.g. stop filling up your inventory with cobblestone"
		"- Can attach a lamp, equal to holding a torch in offhand"
		"- Can attach a magnet, to slowly pull items into you"
		""
		""
		"&lAll actions require power so make sure to socket an appropiate battery to suite your needs. &r"
		""
		""
		"&7&o&lTip:&r &o&7For block chewing to work you also need a Crush Head&r&r"
	]
	quest.1333C98733E8948C.quest_desc: [
		"Optional. The &eCopper Crusher Chassis&r is slightly more energy efficient"
		""
		"&aBuild:&r"
		"- Craft a &eCopper Crusher Chassis&r."
		"- Craft a &eCopper Crush Head&r."
	]
	quest.1333C98733E8948C.quest_subtitle: "A conductive crusher body."
	quest.1333C98733E8948C.title: "Copper Crusher"
	quest.135EB1E2D3366D98.quest_desc: [
		"You are entering recipes where heat control matters. A machine can have enough heat and still fail if control is poor."
		""
		"- &eMin Temperature:&r work waits below this."
		"- &eMax Temperature:&r going above this can create failed outputs."
		"- &eHeat Stability:&r helps the machine stay near the target heat."
		"- &eOverheat:&r gives more room before heat becomes unsafe."
		"- You only risk overheating a material when changing between two different. "
		""
		""
		"&7Tip: Heat Cores raise heat capability. Servos and stability make the process safer.&r"
	]
	quest.135EB1E2D3366D98.quest_subtitle: "Getting varmer"
	quest.1427760B7576D8D6.quest_desc: [
		"You might need to upgrade to a Bronze Alloy Furnace, deepending how you current alloy furnace is equipped."
		""
		"&aCraft:&r"
		"- Invar blend from iron dust and nickel dust"
	]
	quest.1FACE973E783CB4C.quest_desc: [
		"You need calibrated parts to progress further."
		""
		"Calibration stability is rolled when the component is made. Better Resonance gear can push that roll higher."
		""
		"&eQuality&r raises both low and high rolls."
		"&eStability&r raises low rolls."
		"&ePrecision&r narrows the roll range."
		"&eBattery Cell&r avoids the no-cell quality penalty."
		""
		"Look for &eHarmonic&r, &eAnchoring&r, and &eExacting&r affixes on the calibrator and its gear."
	]
	quest.1FACE973E783CB4C.title: "Calibration needed"
	quest.22A86431ABEC9DD3.quest_desc: [
		"Instead of using Cavitation generator for power you can use it to produce nitrogen."
		""
		""
		""
		"&eUse:&r"
		"- Can be used in the ammonia power chain"
	]
	quest.22A86431ABEC9DD3.title: "Nitrogen production"
	quest.23011878EBC32FC2.quest_desc: ["Boring and simple energy storage"]
	quest.2B8333FC1B90FDF8.title: "READ: You"
	quest.2C865B9D41D7EEBB.quest_desc: ["Some extra harndess is needed"]
	quest.2DD5120E11128BFD.quest_desc: [
		"You need to reach a minimum of 900 degrees to be able to process steel in an alloy furnace. As you can see there is two steel recipes, with different heat target. We will choose the lower target since we don't have any machine reaching 1100 degrees."
		""
		""
		"&bCraft:&r"
		"- Craft Bronze Alloy Furnace"
		"- Bronze Heat Core"
		"- Iron/copper/bronze battery, unless you have one from before"
	]
	quest.2DD5120E11128BFD.title: "Alloy Furnace"
	quest.301EC3DBE0E3AFE6.quest_desc: ["You need to be able to make electric circuit to advance into stage 3 and 4."]
	quest.36FD86C58309204A.quest_desc: [
		"This is your first introduction to more deterministic crafting. This allows you to target specific mods, either for adding or upgrading."
		"Not all mods are available through deterministic crafting."
	]
	quest.37A6C9E1284B5D10.quest_desc: [
		"&6RNGTech&r wants to bring RPG elements to machines. It's heavily influenced by ARPG. While also trying to remove painpoints present in other mods"
		""
		"At each stage you will be introduced to new mechanics and hurdles to overcome."
		""
		"&aStage 0-2:&r You will begin setting up your power and your first crusher"
		"&aStage 3-4:&r Power pressure and the need to make alloys. The main goal is bring the factory into Steel Age"
		"&aStage 5-6:&r Lube up your factory, calibrate the tools and scale your power production to new heights"
		"&aStage 7+:&r TBA"
	]
	quest.37A6C9E1284B5D10.quest_subtitle: "Machines are built in layers."
	quest.37A6C9E1284B5D10.title: "&6RNGTech&r - Read This First"
	quest.37A6C9E1284B5D11.quest_desc: [
		"How do we achieve RPG in a tech mod for minecraft? simple, we let machines be our characters and equip them with gear"
		""
		"- &eChassis&r set base stats and limits how advance components you can equip"
		"- &eBattery Cells&r decide how much energy a machine can receive, store, and send"
		"- &eProcessing Gear&r think of this as your main weapon. To tackle tougher material you need a hard crushing head. Same goes for furnace, keep an eye out for temperature."
		"- &eControl Gear&r at later stages you will need to add utility components. Usuall adding additional behaviour.."
		""
		"&7&oTip: when a machine feels bad, check its Gear before replacing the whole block.&r"
	]
	quest.37A6C9E1284B5D11.quest_subtitle: "Why so many parts?"
	quest.37A6C9E1284B5D11.title: "Read: Component Roles"
	quest.37A6C9E1284B5D12.quest_desc: [
		"&aRead:&r Most RNGTech machines, parts, and Battery Cells can roll affixes. Affixes change stats like speed, output amount, efficiency, stability, transfer, or capacity."
		""
		"This quest line will take you through the ways you can interact with affixes"
		""
		"&7&oTip: early machines feel rough when you ignore components.&r"
	]
	quest.37A6C9E1284B5D12.quest_subtitle: "Stats can roll before you refine them."
	quest.37A6C9E1284B5D12.title: "Read: Affixes"
	quest.37A6C9E1284B5D13.quest_desc: [
		"To get started with bigger tools you need plats. Early game this done by using a &eForming Hammer&r"
		""
		"&aBuild:&r"
		"- Craft a &eForming Hammer&r."
		"- Hammer basic ingots into &eIron Plates&r and &eCopper Plates&r."
	]
	quest.37A6C9E1284B5D13.quest_subtitle: "Manual plates before machine tooling."
	quest.37A6C9E1284B5D13.title: "Forming Hammer"
	quest.37A6C9E1284B5D14.quest_desc: [
		"&eBattery Cells&r are Gear. They add portable &bFE&r storage and remove no-cell penalties in machines that use them."
		""
		"&aBuild:&r"
		"- Make an &eIron Battery Cell&r."
		""
		"&aUse:&r"
		"- Cells are installed in the Gear tab"
	]
	quest.37A6C9E1284B5D14.quest_subtitle: "Portable FE for machine buffers."
	quest.37A6C9E1284B5D14.title: "Serious First Cell"
	quest.37A6C9E1284B5D15.quest_desc: [
		"Optional. Wooden crusher and related wooden gear can only be used to process organic material"
		""
		"&aBuild:&r"
		"- Make a &ePotato Battery Cell&r."
		"- Make a &eWooden Battery Chassis&r."
		"- Make a &eWooden Crusher Chassis&r"
		""
		"&aUse:&r"
		"- Perhaps you can find a use for it"
		"- Do not build the main factory around this unless you enjoy suffering."
	]
	quest.37A6C9E1284B5D15.quest_subtitle: "Optional. It works, with pain."
	quest.37A6C9E1284B5D15.title: "Silly Power"
	quest.37A6C9E1284B5D16.quest_desc: ["Time to start working on your factory. "]
	quest.37A6C9E1284B5D16.quest_subtitle: "Install the parts before blaming the machine."
	quest.37A6C9E1284B5D16.title: "Read: Factory Start"
	quest.37A6C9E1284B5D17.quest_desc: [
		"An &eIron Crusher Chassis&r plus an &eIron Crush Head&r is the first step towards ore duplication. A crusher will always be able to crush higher hardness with caveat that energy cost and speed scale with the gap."
		""
		"&aBuild:&r"
		"- Place an &eIron Crusher Chassis&r."
		"- Install an &eIron Crush Head&r in the Gear tab."
		"- Install a Battery Cell."
		""
		"&aUse:&r"
		"- Feed finite ore here before smelting."
		"- Power it from the &eCrude Solid Fuel Burner&r until stronger generators arrive."
	]
	quest.37A6C9E1284B5D17.quest_subtitle: "The head does the hard work."
	quest.37A6C9E1284B5D17.title: "Iron Crusher"
	quest.37A6C9E1284B5D18.quest_desc: [
		"The Crusher can improve output in two different ways."
		""
		"- &eOutput Amount&r is deterministic. Fractional bonuses are saved until they add up to an extra output."
		"- &eSuper Output&r is a separate chance for one extra base output."
		""
		"&7Tip: steady repeated processing makes Output Amount valuable even when it is not a whole number yet.&r"
		""
		"&aBuild:&r"
		"- Run enough ore to collect &eCrushed Iron&r and &eCrushed Copper&r."
		""
		"&aUse:&r"
		"- Route raw ore into the Crusher first."
		"- When power allows, crush the crushed output into dust before smelting."
		"- Send crushed outputs to Furnace, Mekanism, Create, or Oritech depending on the pack path."
	]
	quest.37A6C9E1284B5D18.quest_subtitle: "Finite ore goes farther here."
	quest.37A6C9E1284B5D18.title: "Ore Multiplication"
	quest.37A6C9E1284B5D19.quest_desc: [
		"The &eRNGTech Furnace&r is the only non-electric furnace able to maintain high enough heat to smelt the crushed ore"
		""
		""
		"&aBuild:&r"
		"- Craft a &eFurnace&r."
		""
		"&aUse:&r"
		"- Smelt crushed ore or dust into usable ingots."
		"- Move into electric furnace after learning about eletric circuits in Stage 3-4"
	]
	quest.37A6C9E1284B5D19.quest_subtitle: "Solid-fuel smelting after duplication."
	quest.37A6C9E1284B5D19.title: "Hotter Furnace "
	quest.37A6C9E1284B5D1A.quest_desc: [
		"&eCable&r and &eUniversal Connectors&r are the physical network for RNGTech routing item/energy/fluid. One cable to rule them all. It's the connectors that decide throughput. So if you see a spike in demand from one machine you can easily switch to a better connector without the need replacing the cables. "
		""
		"All connectors support many-to-many. Meaning you can send water and &bcarbon exhaust&r on the same channel to one or many &bAlgae Photobioreactors&r"
		""
		""
		"{@pagebreak}"
		""
		"&aFeatures:&r"
		"- Up to 15 separate channels per type per cable-network"
		"- Multi-to-multi transfer."
		"- Priorty by mode"
		"- Connection tier to hard limit machines on a network. E.g. intentionally setting a lower FE/t for a specific machine"
		"- Network tab to see stats for current cable-network"
		"- Can set the attachment per interface. This allows you to hide the cables nicely."
		""
		""
		"&aBuild:&r"
		"- Craft &eCable&r."
		"- Craft &eUniversal Connectors&r."
		"- Craft a &eWrench&r for connector overlays and cable-link control."
		""
		"&aUse:&r"
		"- Use direct adjacency while you are still missing connector modules."
		"- Install Energy, Fluid, or Item Connectors once the Metal Press can make them."
		"- Pick one nearby Battery Chassis path before pushing into Stage 3-4."
		""
		""
		"{@pagebreak}"
		""
		"&aVocabulary&r"
		"- cable-network. all cables that are directly attached to each other"
		"- Interface. Fluid and item has three interfaces. Each with separate connector. Energy only has 1 interface"
		"- Channel. Each interface support up 15 channels. Separate network within the network"
	]
	quest.37A6C9E1284B5D1A.quest_subtitle: "Route shells now, modules later."
	quest.37A6C9E1284B5D1A.title: "Cable Backbone"
	quest.37A6C9E1284B5D1B.quest_desc: [
		"&aRead:&r Stage 3-4 will put preassure on both resources and power"
		""
		"&aWhat changes:&r"
		"- You need to start caring about Max Temperature"
		"- Keep a steady flow of power"
		"- You will start expericing failure if you don't meet the process requirements"
		""
		"&aGoal:&r"
		"- Upgrade machine park to steel."
		""
		"&7&oTip: Stage 4 really sets the foundation. Use it for factory lines you plan to keep.&r"
	]
	quest.37A6C9E1284B5D1B.quest_subtitle: "Stage 3-4 changes the rules."
	quest.37A6C9E1284B5D1B.title: "Stage 3-4: Stability"
	quest.37A6C9E1284B5D1C.quest_desc: [
		"The &eCrude Solid Fuel Burner&r is the first practical &bFE&r source for RNGTech machines. Your Crusher needs power before it can multiply ore."
		""
		"&aBuild:&r"
		"- Place a &eCrude Solid Fuel Burner&r."
		"- Install an &eIron Fuel Box&r."
		"- Add an &eIron Heat Core&r."
		"- Install the &eIron Battery Cell&r you made earlier."
		""
		"&aUse:&r"
		"- Add coal or charcoal."
		"- Put the burner next to the Crusher until connector modules are available."
		"- Extract &bFE&r from the sides."
		"- Use the &eIron Heat Core&r here. Copper Heat Cores belong to the later Copper-stage path."
	]
	quest.37A6C9E1284B5D1C.quest_subtitle: "Fuel in, FE out, then crush ore."
	quest.37A6C9E1284B5D1C.title: "Crude FE Burner"
	quest.37A6C9E1284B5D1D.quest_desc: [
		"Optional path. The &eCopper Battery Chassis&r trades some stability for better early transfer and small burst behavior."
		""
		"&aBuild:&r"
		"- Place a &eCopper Battery Chassis&r."
		"- Install a &eCopper Battery Cell&r."
		""
		"&aUse:&r"
		"- Use this path for early lines that need more &bFE/t&r than Iron can move."
		"- Watch leakage and low stability before scaling it."
	]
	quest.37A6C9E1284B5D1D.quest_subtitle: "Transfer now, stability later."
	quest.37A6C9E1284B5D1D.title: "Copper Bus"
	quest.37A6C9E1284B5D1F.quest_desc: [
		"&aBuild:&r"
		"- Place an &eAffix Forge&r."
		""
		"&aUpgrade:&r"
		"- Add reusable forge upgrades later to unlock lenses, modifier crystals, and resonance operations."
		""
		"&aUse:&r"
		"- See all optional quests attached to this one for how you can interact with it"
	]
	quest.37A6C9E1284B5D1F.title: "Affix Forge"
	quest.37A6C9E1284B5D20.quest_desc: [
		"RNGTech has two recovery paths, and they recover different value."
		""
		"- &ePotential Reactor&r extracts energy from affixes and remaining RP."
		"- &eComponent Recycler&r recovers material value from components and machines."
		""
		"&7Tip: if a stack has good affixes or RP, run it through the Potential Reactor before recycling the stripped item.&r"
	]
	quest.37A6C9E1284B5D20.quest_subtitle: "Old parts can still pay out."
	quest.37A6C9E1284B5D20.title: "Read: Recycling Path"
	quest.37A6C9E1284B5D21.quest_desc: [
		"The &ePotential Reactor&r recovers energy from unused potential and affixes"
		""
		"&aBuild:&r"
		"- Place a &ePotential Reactor&r."
		"- Install an &eIron Reactor Chamber&r."
		"- Add an &eIron Recovery Filter&r."
		"- Add an &eIron Containment Lining&r."
		""
		"&aUse:&r"
		"- Insert old component"
		"- Extract residue from the bottom and &bFE&r from the sides."
	]
	quest.37A6C9E1284B5D21.quest_subtitle: "Recover value before teardown."
	quest.37A6C9E1284B5D21.title: "Potential Reactor"
	quest.37A6C9E1284B5D22.quest_desc: [
		"The &eComponent Recycler&r return some of the crafting material for components. Just make sure you keep the head up to date with current component stage"
		""
		"&aBuild:&r"
		"- Place an &eIron Component Recycler&r."
		"- Install an &eIron Disassembly Head&r."
		""
		"&aUse:&r"
		"- Feed old components from the top."
		"- Pull recovered parts from the bottom."
		""
		"&7&oTip: Component recycler doesn't care about affixes/RP so it's good to strip that before recycling"
	]
	quest.37A6C9E1284B5D22.quest_subtitle: "Teardown without throwing value away."
	quest.37A6C9E1284B5D22.title: "Component Recycler"
	quest.37A6C9E1284B5D23.quest_desc: [
		"&aRead:&r Steel age (Component Stage 4) introduces a lot of new mechanics you need to get familiar with. "
		""
		"- &ePower:&r If you loose power (FE/t) your craft might fail or halt"
	]
	quest.37A6C9E1284B5D23.quest_subtitle: "Control before speed."
	quest.37A6C9E1284B5D23.title: "Stable power"
	quest.37A6C9E1284B5D24.quest_desc: [
		"The &eMetal Press&r has so much better base stats than crude. It allows for demanding recipes. You can keep the crude for slow plate-creation. "
		""
		"&aBuild:&r"
		"- Place a &eMetal Press&r."
		"- Install a suitable Heat Core."
		"- Optional: install a &eSteel Servo&r for better speed and stability"
		""
		"&aUse:&r"
		"- Make &eSteel Plates&r here."
		"- Use Casing, Circuit, and Connector molds"
		""
		""
		""
		"&bTip:&r If you don't have enough heat stability for Steel plates. You can always put a steel servo inside Crude Plate Press"
	]
	quest.37A6C9E1284B5D24.quest_subtitle: "Tooling makes plates reliable."
	quest.37A6C9E1284B5D24.title: "Steel Metal Press"
	quest.37A6C9E1284B5D25.quest_desc: [
		"Steel is the Stage 4 factory floor. Output guards, stronger cells, and refined Gear separate stable lines from cheap ones."
		""
		"&aBuild:&r"
		"- Upgrade to &eSteel Crusher&r and &eSteel Furnace Chassis&r."
		"- Add a &eSteel Battery Chassis&r."
		"- Upgrade the Crush Head too."
		""
		"&aUse:&r"
		"- Keep the best rolled parts for long-lived production lines."
	]
	quest.37A6C9E1284B5D25.title: "Steel Factory Ready"
	quest.37A6C9E1284B5D26.quest_desc: [
		"&aRead:&r Stage 5 and 6 is mostly about control fluids. You get accesss to a few new power generations built in previous tech,."
		""
		"Most quest are optional part from a few that will be gates to unlock next stage. Even though they are optional, you will still need more power production at next stage so take your time to go through them."
		""
		"&aWhat changes:&r"
		"- &bLubricant&r get added to more advanced machine parts"
		"- Coal gasification creates syngas for Stage 5 active power."
		"- Methane reforming creates hydrogen for ammonia chemistry."
		"- Servos and calibrated components prepare for stricter recipes."
	]
	quest.37A6C9E1284B5D26.quest_subtitle: "Gas power before ammonia."
	quest.37A6C9E1284B5D26.title: "Stage 5-6: Fluids and Chemistry"
	quest.37A6C9E1284B5D27.quest_desc: [
		"The &eMelter&r introduces tanks, heat, crushing gear, optional fluid output, and &bLubricant&r."
		""
		"&aBuild:&r"
		"- Place a &eMelter&r."
		"- Install a Heat Core and Crush Head."
		"- Install a Fluid Pump of any tier to allow extraction"
		"- Melt &ePlant Reagent&r plus &eResin&r into &bLubricant&r."
		""
		"&aUse:&r"
		"- Bucket lubricant early."
		"- Pump lubricant once the factory needs steady output."
	]
	quest.37A6C9E1284B5D27.quest_subtitle: "Heat turns organics into motion control."
	quest.37A6C9E1284B5D27.title: "Melter and Lubricant"
	quest.37A6C9E1284B5D28.quest_desc: [
		"&eFluid Pumps&r unlocks the ability for melter to pump fluids out into a fluid network or tank."
		"&eServos&r can be used to improve processing, heat insulation and other more generic stats"
	]
	quest.37A6C9E1284B5D28.quest_subtitle: "Unlock fluid transport"
	quest.37A6C9E1284B5D28.title: "Pumps and Servos"
	quest.37A6C9E1284B5D2D.quest_desc: [
		"&aRead:&r Stage 7+ builds permanent infrastructure for high &bFE/t&r systems. This stage allows you to unlock the heighest tier affixes. Including the craft only affix tier 7."
		""
		"&aWhat changes:&r"
		"- You may get gated by affix roles. Lookout for stability, max heat and other relevant affixes to reach breakpoints"
	]
	quest.37A6C9E1284B5D2D.quest_subtitle: "Permanent machines, permanent costs."
	quest.37A6C9E1284B5D2D.title: "Stage 7+: Infrastructure"
	quest.37A6C9E1284B5D2E.quest_desc: [
		"Tungstensteel chassis support dense, long-lived production. Place them in permanent layouts."
		""
		"&aBuild:&r"
		"- Upgrade a Crusher into &eTungstensteel&r."
		"- Upgrade a Furnace into &eTungstensteel&r."
		"- Add a &eTungstensteel Crush Head&r."
		""
		"&aUse:&r"
		"- Place this line where AE2, pipes, and power can scale around it."
	]
	quest.37A6C9E1284B5D2E.quest_subtitle: "Dense production wants dense planning."
	quest.37A6C9E1284B5D2E.title: "Tungstensteel Line"
	quest.37A6C9E1284B5D2F.quest_desc: [
		"&eNullite Battery Cells&r allows for higher tier affixes."
		""
		"&aBuild:&r"
		"- Craft a &eNullite Battery Cell&r or how many you like."
		"- Place a &eNullite Battery Chassis&r."
		""
		"&aUse:&r"
		"- Buffer critical processing, calibration, or fluid lines."
		"- Keep good rolled cells."
	]
	quest.37A6C9E1284B5D2F.quest_subtitle: "High-tier cells for high-tier machines."
	quest.37A6C9E1284B5D2F.title: "Nullite Storage"
	quest.37A6C9E1284B5D30.quest_desc: [
		"High-stage pumps and servos allows for the highest tier affixes and takes your machine speeds to new heights"
		""
		"&aBuild:&r"
		"- Craft a &eTungstensteel Fluid Pump&r."
		"- Craft a &eTungstensteel Servo&r."
		""
		"&aUse:&r"
		"- Feed lubricant and future fluids into automated lines."
		"- Reserve these parts for machines that need the throughput."
	]
	quest.37A6C9E1284B5D30.quest_subtitle: "Move fluids at factory scale."
	quest.37A6C9E1284B5D30.title: "High-Stage Fluid Control"
	quest.37A6C9E1284B5D31.quest_desc: ["Congratulation you have reached the end"]
	quest.37A6C9E1284B5D31.quest_subtitle: "The End"
	quest.37A6C9E1284B5D31.title: "Done"
	quest.37A6C9E1284B5D32.quest_desc: [
		"More power hungry than iron for the same craft."
		"Minimum heat without affixes: 1000. Affixes may increase this further."
		""
		"&aBuild:&r"
		"- Craft a &eCopper Furnace Chassis&r."
		"- Install a &eCopper Heat Core&r."
		"- Feed it with a Battery Cell and steady &bFE&r."
	]
	quest.37A6C9E1284B5D32.quest_subtitle: "Faster heat, thinner margin."
	quest.37A6C9E1284B5D32.title: "Copper Furnace"
	quest.37A6C9E1284B5D33.quest_desc: [
		"Even hotter than copper without the downside. Has a bonus to melting blends."
		"Minimum heat without affixes: 1200. Affixes may increase this further."
		""
		"&aBuild:&r"
		"- Craft a &eBronze Furnace Chassis&r."
		"- Install a &eBronze Heat Core&r."
	]
	quest.37A6C9E1284B5D33.title: "Bronze"
	quest.37A6C9E1284B5D34.quest_desc: [
		"&aGate:&r Complete any one electric furnace path to prove the press-to-smelter lesson."
		""
		"&aUse:&r"
		"- &eIron&r is the plain baseline."
		"- &eCopper&r pushes transfer and heat sooner."
		""
		"&7&oTip: this diamond is an OR gate. Extra sidegrades are useful, but not required here.&r"
	]
	quest.37A6C9E1284B5D34.quest_subtitle: "Any one electric smelter unlocks the line."
	quest.37A6C9E1284B5D34.title: "Smelting Path Selected"
	quest.37A6C9E1284B5D35.quest_desc: [
		"Optional path. The &eIron Battery Chassis&r is a reliable one-cell rack with strong per-cell modifier focus."
		""
		"&aBuild:&r"
		"- Place an &eIron Battery Chassis&r."
		"- Install an &eIron Battery Cell&r."
		""
		"&aUse:&r"
		"- Pick this path for predictable storage and no burst risk."
		"- Keep a good rolled cell; it can move into later machines."
	]
	quest.37A6C9E1284B5D35.quest_subtitle: "Stable storage, low drama."
	quest.37A6C9E1284B5D35.title: "Iron Rack"
	quest.37A6C9E1284B5D36.quest_desc: [
		"Optional path. The &eGold Battery Chassis&r is a burst bank. It can push high output for short windows, but its stability is poor."
		""
		"&aBuild:&r"
		"- Place a &eGold Battery Chassis&r."
		"- Feed it with cells that can survive the output demand."
		""
		"&aUse:&r"
		"- Pick this path for startup spikes or hungry machines."
		"- Do not treat burst output as free storage."
	]
	quest.37A6C9E1284B5D36.quest_subtitle: "High burst with overload risk."
	quest.37A6C9E1284B5D36.title: "Gold Flash Bus"
	quest.37A6C9E1284B5D37.quest_desc: [
		"&aGate:&r Complete any one Battery Chassis path to continue."
		""
		"Battery Cells and Battery Chassis do different jobs."
		""
		"- &eBattery Cells&r are Gear. They add portable &bFE&r storage and remove no-cell penalties in machines that use them."
		"- &eBattery Chassis&r are storage blocks. Their output depends on the installed cells and how charged those cells are."
		""
		"&aUse:&r"
		"- &eIron&r is steady and simple."
		"- &eCopper&r moves more &bFE/t&r with light leakage."
		""
		"&7Tip: a chassis with one full cell and several empty cells can still be limited by that one cell's output.&r"
	]
	quest.37A6C9E1284B5D37.quest_subtitle: "Any one bank proves the storage lesson."
	quest.37A6C9E1284B5D37.title: "Storage Path Selected"
	quest.37A6C9E1284B5D38.quest_desc: [
		"You still play an important role in this adventure. Who else will bring in all the materials."
		""
		"To achieve this we bring you modular tools. Like machines/components these also have RPG-modifiers (affixes)"
		""
		"&aParts:&r"
		"- Heads choose the family: Pick, Hammer, Shovel, Digger, Axe, or Treefeller."
		"- Rods set durability, handling, transfer, control, and Battery Support."
		"- Battery Cells add &bFE&r work. Tools still fall back to durability-only work when &bFE&r is empty."
		"- Matching repair materials restore damaged tools without deleting installed parts."
		""
		"&7&oTip: heads, rods, and assembled tools all keep their own rolls. Read the tooltips before replacing parts.&r"
	]
	quest.37A6C9E1284B5D38.quest_subtitle: "Field tools are built from parts."
	quest.37A6C9E1284B5D38.title: "Read: Modular Tools"
	quest.37A6C9E1284B5D39.quest_desc: [
		"The &eTool Bench&r assembles modular tools and swaps parts"
		""
		"&aBuild:&r"
		"- Craft a &eTool Bench&r."
		""
		"&aUse:&r"
		"- Insert a Tool Head and Tool Rod to assemble a new tool."
		"- Install a Tiny Anvil to unlock Hammers and Treefellers."
		"- Remove, repair, or swap parts without loosing your affixes"
	]
	quest.37A6C9E1284B5D39.quest_subtitle: "Assemble, swap, and keep the good parts."
	quest.37A6C9E1284B5D39.title: "Tool Bench"
	quest.37A6C9E1284B5D3A.quest_desc: [
		"You first modular tool"
		""
		"&aBuild:&r"
		"- Craft a &eFlint Pick Head&r."
		"- Craft a &eWooden Tool Rod&r."
	]
	quest.37A6C9E1284B5D3A.title: "Tool components"
	quest.37A6C9E1284B5D3B.quest_desc: [
		"A &eTiny Anvil&r unlocks the heavy starter heads. Flint Hammers and Treefellers are crude, but they teach the slot rules before metal parts get expensive."
		""
		"&aBuild:&r"
		"- Craft a &eTiny Anvil&r and install it in the Tool Bench Gear tab."
		"- Craft a &eFlint Hammer Head&r."
		"- Craft a &eFlint Treefeller Head&r."
		"- Assemble a &eModular Hammer&r."
		"- Assemble a &eModular Treefeller&r."
		""
		"&aUse:&r"
		"- Hammers break a 3x3 area when the extra targets are valid pick-minable blocks."
		"- Treefellers clear connected logs up to their effective limit."
		"- Upgrade the heads later while preserving useful rod data."
	]
	quest.37A6C9E1284B5D3B.quest_subtitle: "Tiny Anvil unlocks heavy heads."
	quest.37A6C9E1284B5D3B.title: "Starter Heavy Tools"
	quest.37A6C9E1284B5D3C.quest_desc: [
		"Optional. Flint Shovels and Axes round out the primitive tool kit without spending metal."
		""
		"&aBuild:&r"
		"- Craft a &eFlint Shovel Head&r."
		"- Craft a &eFlint Axe Head&r."
		"- Assemble a &eModular Shovel&r and &eModular Axe&r."
		""
		"&aUse:&r"
		"- Swap heads onto a compatible rod instead of rebuilding the whole tool."
		"- Repair Flint-headed tools with flint when they wear down."
		"- Axes break one matching block."
		"- Shovels cover early dirt, gravel, and sand work."
	]
	quest.37A6C9E1284B5D3C.quest_subtitle: "Cheap heads, useful swaps."
	quest.37A6C9E1284B5D3C.title: "Starter Utility Tools"
	quest.37A6C9E1284B5D3E.quest_desc: [
		"Optional. The &eBio Generator&r is the farm-backed early power source. It burns tagged crops, biomass, Organic Reagent, Composted Biomass, and Rich Biomass for &bFE&r."
		""
		"&aBuild:&r"
		"- Place a &eBio Generator&r."
		"- Install a &eBio Chamber&r and a compatible Battery Cell in the Gear tab."
		""
		"&aUse:&r"
		"- Feed potatoes, carrots, bread, saplings, seeds, Plant Reagent, or Organic Reagent."
		"- Extract &bFE&r from the sides."
		"- Keep crop-focused Bio Chamber rolls for the farms you actually run."
	]
	quest.37A6C9E1284B5D3E.quest_subtitle: "Farm output can become FE."
	quest.37A6C9E1284B5D3E.title: "Organic Generator"
	quest.37A6C9E1284B5D3F.quest_desc: [
		"Optional. The &eWooden Composter&r turns bulk plant matter into &eComposted Biomass&r for the Bio Generator."
		""
		"&aBuild:&r"
		"- Place a &eWooden Composter&r."
		"- Fill it with compostable plant inputs."
		"- Add water for the faster wet recipe."
		""
		"&aUse:&r"
		"- It batches &e8&r inputs into &e1&r Composted Biomass."
		"- It gets speed bonuses from a large input buffer and from varied input types."
		"- Pull prepared fuel from the bottom output."
	]
	quest.37A6C9E1284B5D3F.quest_subtitle: "Bulk plants become denser fuel."
	quest.37A6C9E1284B5D3F.title: "Wooden Composter"
	quest.37A6C9E1284B5D40.quest_desc: [
		"Optional. &eRich Biomass&r is the stronger prepared organic fuel."
		""
		"&aBuild:&r"
		"- Craft Rich Biomass from &eComposted Biomass&r and a catalyst item accepted by the rich biomass tag."
		""
		"&aUse:&r"
		"- Burn it in the Bio Generator when you want fewer fuel insertions."
		"- It is Bio Generator fuel only, not furnace fuel and not solid fuel burner fuel."
	]
	quest.37A6C9E1284B5D40.quest_subtitle: "Prepared biomass, higher fuel value."
	quest.37A6C9E1284B5D40.title: "Rich Biomass"
	quest.37A6C9E1284B5D41.quest_desc: [
		"Optional read. The &eAlloy Furnace&r is the full-yield alloy path once Bronze Casing and the Bronze Alloy Crucible are reachable."
		""
		"&aUse:&r"
		"- Pick this path when you want full-yield Bronze before the Stage 4 factory settles in."
		"- Upgrade the chassis and crucible together as alloy inputs get stricter."
		"- Keep this as a side lesson rather than a progression gate until every required component has a survival recipe."
	]
	quest.37A6C9E1284B5D41.quest_subtitle: "Full-yield alloys without the dust tax."
	quest.37A6C9E1284B5D41.title: "Read: Alloy Furnace"
	quest.37A6C9E1284B5D42.quest_desc: [""]
	quest.37A6C9E1284B5D43.quest_desc: [
		"Optional. &eCrude Solar Panels&r provide daylight &bFE&r without fuel. They are weak, but they teach sky access, weather loss, and side extraction."
		""
		"&aBuild:&r"
		"- Place a &eCrude Solar Panel&r with open sky."
		""
		"&aUse:&r"
		"- Pull &bFE&r from the panel into nearby storage or machines."
		"- Expect lower or zero production in bad weather, at night, or in unsupported dimensions."
		"- Treat this as supplemental power until array control opens."
	]
	quest.37A6C9E1284B5D43.quest_subtitle: "Fuel-free trickle power."
	quest.37A6C9E1284B5D43.title: "Crude Solar"
	quest.37A6C9E1284B5D45.quest_desc: [
		"Optional. Core component in creating tanks is &bTank Frame&rs"
		""
		"&aCraft:&r"
		"- A Tank Frame"
		""
		""
		"&aUse:&r"
		"- Depending your current progress make an appropiate Fluid Tank (Iron/copper/bronze)"
	]
	quest.37A6C9E1284B5D45.quest_subtitle: "A local buffer for liquids."
	quest.37A6C9E1284B5D45.title: "Fluid Tank"
	quest.37A6C9E1284B5D46.quest_desc: [
		"Optional. &eBronze Fluid Tanks&r are the last plain tank tier before active compression starts."
		""
		"&aBuild:&r"
		"- &eBronze Fluid tank&r."
		""
		"&aUse:&r"
		"- Keep Bronze tanks for cheap fluid storage."
		"- Move to Steel when you need compressed storage.."
	]
	quest.37A6C9E1284B5D46.quest_subtitle: "The last plain tank step."
	quest.37A6C9E1284B5D46.title: "Bronze Tank Petal"
	quest.37A6C9E1284B5D47.quest_desc: [
		"Optional. &eSteel Compressor Tanks&r add active compression. They need a Battery Cell, at least one Servo, and &bFE&r."
		""
		"&aBuild:&r"
		"- Place a &eSteel Compressor Tank&r."
		"- Install a compatible Battery Cell."
		"- Install at least one &eSteel Servo&r."
		""
		"&aUse:&r"
		"- Feed loose fluid, then let the tank compress it while powered."
		"- More and better Servos improve active compression behavior."
		""
		""
		"&aInfo:&r"
		"- It only cost FE when compressing/decompressing fluid. At idle the energy cost is 0"
	]
	quest.37A6C9E1284B5D47.quest_subtitle: "Powered liquid storage starts here."
	quest.37A6C9E1284B5D47.title: "Steel Compressor Tank"
	quest.37A6C9E1284B5D49.quest_desc: [
		"The &eCrude Metal Press&r allows you to create electric circuits"
		""
		"&aBuild:&r"
		"- Place a &eCrude Metal Press&r."
		"- Install a &eCircuit Mold&r."
		"- Install an &eBronze Heat Core&r."
		"- Install a battery"
	]
	quest.37A6C9E1284B5D49.quest_subtitle: "Allows the creation of circuits"
	quest.37A6C9E1284B5D49.title: "Crude Metal Press"
	quest.37A6C9E1284B5D4A.quest_desc: [
		"Optional. Connector modules turn Cable and Universal Connector into a dynamic solution that scales with your progress"
		""
		"&aBuild:&r"
		"- Make a &eConnector Mold&r."
		"- Craft a &eBasic Energy Connector&r, &eBasic Fluid Connector&r, and &eBasic Item Connector&r."
		""
		"&aUse:&r"
		"- Install modules in Universal Connector tabs or directly on Cable sides when allowed."
		"- Set channel, mode, and Attach As per module."
	]
	quest.37A6C9E1284B5D4A.quest_subtitle: "Modules make the backbone useful."
	quest.37A6C9E1284B5D4A.title: "Connector Modules"
	quest.37A6C9E1284B5D4D.quest_desc: [
		"Optional. Run crushed ore through the Crusher again before smelting."
		""
		"&aBuild:&r"
		"- Crush &eCrushed Iron&r into &eIron Dust&r."
		"- Crush &eCrushed Copper&r into &eCopper Dust&r."
		""
		"&aUse:&r"
		"- This is used to lesser the energy required to smelt it"
	]
	quest.37A6C9E1284B5D4D.quest_subtitle: "Second-pass crushing pays back."
	quest.37A6C9E1284B5D4D.title: "Keep Crushing It"
	quest.37A6C9E1284B5D4E.quest_desc: [
		"Iron furnace. Your first powered furnace in the pack."
		"Minimum heat without affixes: 800. Affixes may increase this further."
		""
		"&aBuild:&r"
		"- Craft an &eIron Furnace Chassis&r."
		"- Install an &eIron Heat Core&r."
		"- Give it a Battery Cell and external &bFE&r."
	]
	quest.37A6C9E1284B5D4E.quest_subtitle: "Reliable electric smelting starts after press work."
	quest.37A6C9E1284B5D4E.title: "Iron Furnace Chassis"
	quest.39580D0D592ED993.quest_desc: ["Using this allows you to remove a random modifier from an item. Hopefully something you don't care about"]
	quest.3A8FCB54EB8B1E89.title: "Harvest the Sun"
	quest.3B2B69FA1DBA2CCE.quest_desc: [""]
	quest.3C127DCECF78A9B0.quest_desc: ["You might have noticed the Dehumidifier accept items. You can throw in some coal dust and have it automatically turn water into carbon exhaust. "]
	quest.3C127DCECF78A9B0.title: "Carbon"
	quest.3E0E5C8A95264360.quest_desc: ["Keep upgrading your tools, switch out old parts and find the one that fits your needs"]
	quest.42BFA6CFEA87EC68.quest_desc: [
		"To progress, you need Nether Quartz. So take a trip to the Nether."
		""
		"&bTip:&r Lava and water buckets can make a temporary portal if obsidian is tight."
	]
	quest.42BFA6CFEA87EC68.quest_subtitle: "Nether Quartz opens the press route."
	quest.42BFA6CFEA87EC68.title: "Nether Quartz"
	quest.44B6B0AADE341E23.quest_desc: [
		"Configurator allows you to copy/paste per page configuration of a &lUniversal Connector&r. It can also insert modules if enable it under config menu (enabled by &lkeybind&r)"
		""
		"Common usecase is hooking up multiple of the same machine"
		"- Hook up one machine"
		"- Activate module insert"
		"- Sneak right click and select copy all"
		"- Paste the configuration with &bsneak + right click&r on additional universal connector"
	]
	quest.4653761EC24BB69A.quest_desc: [
		"To get a steady flow of water you can build a multiblock wooden dehumidifier. "
		"You are allowed to make it bigger than suggested, however max effective is 25."
		""
		"The multiblock is a classic square with empty center"
		""
		"F = Frame"
		"A = Air"
		"C = Controller"
		""
		"Layer 1"
		""
		"FFF"
		"FFF"
		"FFF"
		""
		"Layer 2"
		""
		"FCF"
		"FAF"
		"FFF"
		""
		"Layer 3"
		""
		"FFF"
		"FFF"
		"FFF"
	]
	quest.4653761EC24BB69A.title: "Water source"
	quest.46A1F2C0DE100001.quest_desc: [
		"&aCraft:&r"
		"- Craft &eMachine Frame&r."
	]
	quest.46A1F2C0DE100001.title: "Machine Frame"
	quest.46A1F2C0DE100010.quest_desc: [
		"&aCraft:&r"
		"- Craft &eAdvanced Electric Circuit&r."
	]
	quest.46A1F2C0DE100010.title: "Advanced Electric Circuit"
	quest.46A1F2C0DE100020.quest_desc: [
		"&aCraft:&r"
		"- Craft &eReinforced Machine Frame&r."
	]
	quest.46A1F2C0DE100020.title: "Reinforced Machine Frame"
	quest.46A1F2C0DE100030.quest_desc: [
		"&aCraft:&r"
		"- Craft &eAdvanced Machine Frame&r."
	]
	quest.46A1F2C0DE100030.title: "Advanced Machine Frame"
	quest.46A1F2C0DE100040.quest_desc: [
		"&aCraft:&r"
		"- Craft &eElite Electric Circuit&r."
	]
	quest.46A1F2C0DE100040.title: "Elite Electric Circuit"
	quest.46A1F2C0DE100050.quest_desc: [
		"&aCraft:&r"
		"- Craft &eExotic Machine Frame&r."
	]
	quest.46A1F2C0DE100050.title: "Exotic Machine Frame"
	quest.46A1F2C0DE100060.quest_desc: [
		"&aCraft:&r"
		"- Craft &eUltimate Electric Circuit&r."
	]
	quest.46A1F2C0DE100060.title: "Ultimate Electric Circuit"
	quest.46A1F2C0DE100070.quest_desc: [
		"&aBuild:&r"
		"- Craft an &eExotic Affix Forge&r."
		""
		"&aUse:&r"
		"- Run Stage 8 powered refinement recipes for long-term targets."
	]
	quest.46A1F2C0DE100070.title: "Exotic Affix Forge"
	quest.4CC5AA5185C3D06B.quest_desc: [
		"Now that you have access to creating various fluids. You star bulk producing batteries, make stuff cheaper in &bComponent Assembler&r"
		""
		""
		"&aCraft:&r"
		"- Component assembler"
	]
	quest.4F5AA1D34A0C1A4C.quest_desc: [
		"Press some Electric Circuits"
		""
		"&aBuild:&r"
		"- Use the &eCircuit Mold&r to press a &eBasic Electric Circuit&r."
		""
		"&aUse:&r"
		"- Electric Furnace sidegrades start after this checkpoint."
		"- Keep blocked Alloy Furnace chassis out of the required route."
	]
	quest.4F5AA1D34A0C1A4C.title: "Pressed Circuits"
	quest.51085B8552CE2F6C.quest_desc: [
		"Time to assemble your parts"
		""
		"- Open Tool Bench"
		"- Insert Wooden Tool Rod"
		"- Insert Flint pick head"
		""
		""
		"&aUse:&r"
		"- Compare head, rod, and assembled-tool tooltips."
		"- Repair Flint-headed tools with flint in the Tool Bench or anvil."
		"- Keep strong part rolls for later swaps."
	]
	quest.514C23AEB9AC2C85.quest_desc: ["Always a good idea to keep your tools relevant. Go ahead and create icopper variants of the 3 heavy tools"]
	quest.53F2D28C45DFDD39.quest_desc: [
		"Optional. The &eCopper Component Recycler&r is the early recovery sidegrade for machine parts and failed rolls."
		""
		"&aBuild:&r"
		"- Craft a &eCopper Component Recycler&r."
		""
		"&aUse:&r"
		"- Recycle cheap or bad rolled parts before they clutter storage."
		"- Keep recovery machines near the crafting area, not buried in the processing line."
	]
	quest.53F2D28C45DFDD39.quest_subtitle: "Recover value from bad parts."
	quest.53F2D28C45DFDD39.title: "Copper Recycler"
	quest.56BF8BBA48C36C74.quest_desc: ["Upgrade your &btool bench&r with a tiny anvil to unlock more recipes"]
	quest.56BF8BBA48C36C74.title: "Hammertime"
	quest.59C090170DAE7A69.quest_desc: [
		"&bUse&r"
		"- Insert Iron Ingot and coal into the Alloy furnace"
	]
	quest.5C1326D78226482C.quest_desc: [
		"Your first upgrade to &eAffix Forge&r. This upgrade allows you to use lenses"
		""
		"This is your first introduction to more deterministic crafting. This allows you to target specific mods, either for adding or upgrading."
		"Not all mods are available through deterministic crafting."
	]
	quest.5E1CA6E1D5C00500.quest_desc: [
		"Twice as effective as a max Wooden Dehumidifier, and it works underground."
		""
		""
		"&aBuild:&r"
		"- Craft a &eSilica Gel Dehumidifier&r."
		"- Place two &eSilica Gel Column Casings&r directly above it."
		"- Feed dry beads from the top and drain water from the sides."
	]
	quest.5E1CA6E1D5C00500.title: "Silica Gel Dehumidifier"
	quest.61F18F2CD460DDD9.quest_desc: [
		"Optional. You have multiple ways of generating power. You have a few options"
		"- Organic route, "
		"- Corrode plates"
		"- Solar (requires circuits)"
		"- Keep burning solid fuels"
	]
	quest.61F18F2CD460DDD9.quest_subtitle: "A few ways more to make power"
	quest.61F18F2CD460DDD9.title: "Generators"
	quest.691503A12347F864.quest_desc: ["Improve the performance of Organic Generator"]
	quest.6A3B46D12E418769.quest_desc: ["This allows you to upgrade a random affix. It's especially powerful with a magic item that has two good modifiers."]
	quest.6AD0EAA001CB1D16.quest_desc: ["Top of the line battery"]
	quest.6B295A9B5D422CB1.quest_desc: [
		"You might have noticed items crafted will result in an unidentified version. This item still behave as an unrolled variant. "
		""
		"&aHow to identify&r"
		"- Place in your own crafting grid and take out the item"
		"- Placing an unidentified block on the ground will also identify it."
	]
	quest.6E8257BAA2BB0FDB.quest_desc: ["Roughly 20% faster base speed than iron variant but with a lower durability"]
	quest.7106E7A1B10F0010.quest_desc: [
		"Optional. The &eAlgae Photobioreactor&r is the the next step in getting power from plants"
		""
		"&aBuild:&r"
		"- Craft an &eAlgae Photobioreactor&r."
		"- Supply &eWater&r, &eCarbon Exhaust&r, and light."
		"- Grow &eAlgae Biomass&r and compact it into &eDense Algae Biomass&r."
		""
		"&aUse:&r"
		"- Burn algae items in the &eBio Generator&r."
		"- Carbon Exhaust is the starter input."
		"- This will be repurposed in later stages with a better carbon source"
	]
	quest.7106E7A1B10F0010.quest_subtitle: "Water plus carbon plus light makes fuel."
	quest.7106E7A1B10F0010.title: "Algae Fuel Chain"
	quest.7106E7A1B10F0040.quest_desc: [
		"Optional read. The Photobioreactor accepts better carbon fluids once you get a hang of gases"
		""
		"&aUse:&r"
		"- &eCarbon Exhaust&r is enough to start algae."
		"- &eSyngas&r is a medium upgrade."
		"- &eCarbon Monoxide&r is the best carbon input available"
		""
		"&7Use JEI for the exact fluid amounts and growth times.&r"
	]
	quest.7106E7A1B10F0040.quest_subtitle: "Better carbon speeds algae later."
	quest.7106E7A1B10F0040.title: "Later Carbon Inputs"
	quest.7106E7A1B10F0050.quest_desc: [
		"Step 1. The &eCorrosion Cell&r is the first material-consuming generator in this branch."
		""
		"&aBuild:&r"
		"- Craft a &eCorrosion Cell&r from Steel Casings, Electrolyte, Bus Bar, Machine Frame, and redstone."
		"- Optional: install a compatible Battery Cell in the Gear tab for more stored &bFE&r."
		""
		"&aRun:&r"
		"- Insert &eIron Plate&r or &eCopper Plate&r from the top."
		"- Insert &eElectrolyte&r from the sides."
		"- Pull &bFE&r from the sides and &eCorrosion Residue&r from the bottom."
		"- The machine pauses if the residue slot or energy buffer is full."
	]
	quest.7106E7A1B10F0050.quest_subtitle: "Plate plus electrolyte becomes FE and residue."
	quest.7106E7A1B10F0050.title: "Step 1: Corrosion Cell"
	quest.7106E7A1B10F0060.quest_desc: [
		"Optional. The &eCavitation Generator&r remains the separate gas-input route for this power chapter."
		""
		"&aBuild:&r"
		"- Craft a &eSteel Cavitation Rotor&r and &eSteel Collapse Nozzle&r first."
		"- Craft the &eCavitation Generator&r, then install the rotor and nozzle in Gear."
		"- Optional: add a Heat Core and Battery Cell."
		""
		"&aRun:&r"
		"- Fill the tank with &eWater&r or insert filled water containers from the sides."
		"- Pull &bFE&r from the sides."
		"- Watch heat strain and rotor wear. A fully worn rotor ejects a Pitted Cavitation Rotor from the bottom."
		"- Use this branch for &eNitrogen&r while hydrogen normally comes from SMR."
	]
	quest.7106E7A1B10F0060.quest_subtitle: "Fluid recipes, rotor wear, local strain."
	quest.7106E7A1B10F0060.title: "Step 2: Cavitation Generator"
	quest.7106E7A1B10F0070.quest_desc: [
		"Ammonia power is a two-block chain after gas reforming: a powered support processor plus a generator."
		""
		"&aBuild:&r"
		"- Craft an &eAmmonia Catalyst Bed&r and install it in an &eAmmonia Synthesizer&r."
		"- Craft a &eFuel Cell Membrane&r and install it in an &eAmmonia Fuel Cell&r."
		"- Optional: add a Stage 6+ Battery Cell to the Fuel Cell."
		""
		"&aRun:&r"
		"- Feed the Synthesizer &eNitrogen&r, &eHydrogen&r, and side &bFE&r to make &eAmmonia&r."
		"- Hydrogen normally comes from the &eSteam Methane Reformer&r."
		"- Nitrogen remains a separate gas input."
		"- Move Ammonia into the Fuel Cell."
		"- Pull &bFE&r from Fuel Cell sides and residue from the bottom."
		"- The Synthesizer is not a generator; the Fuel Cell is."
	]
	quest.7106E7A1B10F0070.quest_subtitle: "SMR hydrogen plus nitrogen becomes ammonia."
	quest.7106E7A1B10F0070.title: "Ammonia Power"
	quest.7106E7A1B10F0090.quest_desc: [
		"Vacuum Collapse recipes are powerful, but they care about local stability."
		""
		"&aBuild:&r"
		"- Craft a &eVoid Chamber&r, &eCollapse Nozzle&r, and &eDimensional Stabilizer&r."
		"- Install all three parts in the Gear tab."
		"- Craft &eVoid Catalyst&r from Ender Pearl, Stabilization Crystal, and Tungstensteel Plate."
		""
		"&aRun:&r"
		"- Insert Void Catalyst from the top."
		"- Pull &bFE&r from the sides and &eCollapse Residue&r from the bottom."
		"- The Void Chamber gates recipe stage."
		"- The Collapse Nozzle tunes generation and transfer."
		"- The Dimensional Stabilizer improves stability and residue control."
		"- Keep stability high enough for the recipe before feeding expensive catalysts."
		"- Redstone power pauses the generator."
	]
	quest.7106E7A1B10F0090.quest_subtitle: "Catalyst collapse, stability, large FE batches."
	quest.7106E7A1B10F0090.title: "Vacuum Collapse"
	quest.7106E7A1B10F0100.quest_desc: [
		"Gases behaves as fluid so expect them to work the same. Same fluid connector for universal connector"
		""
		""
		"&aUse:&r"
		"- Store gases in tanks or buckets."
		"- Move them with normal fluid handlers."
		"- Use JEI to inspect gasification, combustion, reforming, and algae recipes."
	]
	quest.7106E7A1B10F0100.quest_subtitle: "Gases are fluids with tags."
	quest.7106E7A1B10F0100.title: "Read: Gas Chemistry"
	quest.7106E7A1B10F0110.quest_desc: [
		"The &eCoal Gasifier&r turns Coal Dust and water into &eSyngas&r plus residue."
		""
		"&aBuild:&r"
		"- Craft a &eCoal Gasifier&r."
		"- Install a Stage 5+ Heat Core."
		"- Feed &eCoal Dust&r and &eWater&r."
		""
		"&aUse:&r"
		"- Syngas is the transition fuel before methane reforming."
	]
	quest.7106E7A1B10F0110.quest_subtitle: "Coal dust becomes syngas."
	quest.7106E7A1B10F0110.title: "Coal Gasifier"
	quest.7106E7A1B10F0120.quest_desc: [
		"The &eSyngas Combustor&r is the Stage 5 active gas generator."
		""
		"&aBuild:&r"
		"- Craft a &eSyngas Combustor&r."
		"- Pipe or bucket in &eSyngas&r."
		""
		"&aRun:&r"
		"- Pull &bFE&r from the sides."
		"- Capture &eCarbon Exhaust&r if the algae branch needs starter carbon."
	]
	quest.7106E7A1B10F0120.quest_subtitle: "Stage 5 gas power."
	quest.7106E7A1B10F0120.title: "Syngas Combustor"
	quest.7106E7A1B10F0130.quest_desc: [
		"&eMethane&r is a better carbon for the Algae photoreactor"
		""
		"&aBuild:&r"
		"- Grow &eAlgae Biomass&r."
		"- Combine it with &eOrganic Reagent&r and water in the &eMelter&r."
		""
		"&aUse:&r"
		"- Methane feeds the Steam Methane Reformer."
	]
	quest.7106E7A1B10F0130.quest_subtitle: "Biomass becomes methane."
	quest.7106E7A1B10F0130.title: "Methane from Biomass"
	quest.7106E7A1B10F0140.quest_desc: [
		"The &eSteam Methane Reformer&r is the normal hydrogen route for ammonia."
		""
		"&aBuild:&r"
		"- Craft a &eSteam Methane Reformer&r and &eReforming Catalyst Bed&r."
		"- Install a Stage 6+ Heat Core and the catalyst bed."
		""
		"&aRun:&r"
		"- Feed &eMethane&r plus water for strong Hydrogen output."
		"- Syngas plus water works, but makes less Hydrogen."
		"- Capture &eCarbon Monoxide&r for better Algae Photobioreactor performance."
	]
	quest.7106E7A1B10F0140.quest_subtitle: "Methane plus steam makes hydrogen."
	quest.7106E7A1B10F0140.title: "Steam Methane Reformer"
	quest.7106E7A1B10F0200.quest_desc: [
		"This branch shows the ore-hardness ladder for RNGTech field tools."
		""
		"&aProgress:&r"
		"- &e1:&r Flint or Iron heads."
		"- &e2:&r Copper or Bronze heads."
		"- &e3:&r Steel heads."
		"- &e4:&r Steel heads with a Diamond Tip."
		"- &e4.5:&r Aluminum begins after Steel plus Diamond Tip can reach Aluminum ore."
		"- &e5:&r Titanium ore band."
		"- &e6:&r Tungsten and Platinum ore band."
		"- &e7:&r Reserved; no current ore blocks are assigned."
		"- &e8:&r Naquadah pack-endgame ore band."
	]
	quest.7106E7A1B10F0200.quest_subtitle: "Ore hardness progression."
	quest.7106E7A1B10F0200.title: "Read: Hardness Scale"
